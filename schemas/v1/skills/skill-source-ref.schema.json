{
  "$defs": {
    "SkillSourceType": {
      "enum": [
        "manual",
        "imported_package",
        "repository",
        "artifact"
      ],
      "title": "SkillSourceType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/skills/skill-source-ref.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "source_id": {
      "minLength": 1,
      "title": "Source Id",
      "type": "string"
    },
    "source_revision": {
      "minLength": 1,
      "title": "Source Revision",
      "type": "string"
    },
    "source_type": {
      "$ref": "#/$defs/SkillSourceType"
    }
  },
  "required": [
    "source_type",
    "source_id",
    "source_revision",
    "content_hash"
  ],
  "title": "SkillSourceRef",
  "type": "object"
}
