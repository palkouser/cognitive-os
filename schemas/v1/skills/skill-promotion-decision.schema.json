{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "SkillActor": {
      "additionalProperties": false,
      "properties": {
        "creator_id": {
          "minLength": 1,
          "title": "Creator Id",
          "type": "string"
        },
        "creator_type": {
          "$ref": "#/$defs/SkillCreatorType"
        }
      },
      "required": [
        "creator_type",
        "creator_id"
      ],
      "title": "SkillActor",
      "type": "object"
    },
    "SkillCreatorType": {
      "enum": [
        "operator",
        "user",
        "import_service",
        "system",
        "provider"
      ],
      "title": "SkillCreatorType",
      "type": "string"
    },
    "SkillPromotionOutcome": {
      "enum": [
        "verify",
        "remain_staged",
        "return_to_draft",
        "requires_review",
        "reject",
        "verification_error"
      ],
      "title": "SkillPromotionOutcome",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/skills/skill-promotion-decision.schema.json",
  "additionalProperties": false,
  "properties": {
    "decided_at": {
      "format": "date-time",
      "title": "Decided At",
      "type": "string"
    },
    "decided_by": {
      "$ref": "#/$defs/SkillActor"
    },
    "decision_id": {
      "format": "uuid",
      "title": "Decision Id",
      "type": "string"
    },
    "outcome": {
      "$ref": "#/$defs/SkillPromotionOutcome"
    },
    "reason_codes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Reason Codes",
      "type": "array"
    },
    "regression_summary": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "skill_id": {
      "format": "uuid",
      "title": "Skill Id",
      "type": "string"
    },
    "verifier_bundle": {
      "$ref": "#/$defs/ArtifactRef"
    }
  },
  "required": [
    "decision_id",
    "skill_id",
    "revision",
    "outcome",
    "verifier_bundle",
    "regression_summary",
    "decided_by",
    "reason_codes",
    "decided_at"
  ],
  "title": "SkillPromotionDecision",
  "type": "object"
}
