{
  "$defs": {
    "SkillApplicabilityResult": {
      "additionalProperties": false,
      "properties": {
        "evaluation_hash": {
          "default": "",
          "title": "Evaluation Hash",
          "type": "string"
        },
        "results": {
          "items": {
            "$ref": "#/$defs/SkillPreconditionResult"
          },
          "title": "Results",
          "type": "array"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        },
        "skill_id": {
          "format": "uuid",
          "title": "Skill Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/SkillApplicabilityStatus"
        }
      },
      "required": [
        "skill_id",
        "revision",
        "status",
        "results"
      ],
      "title": "SkillApplicabilityResult",
      "type": "object"
    },
    "SkillApplicabilityStatus": {
      "enum": [
        "applicable",
        "inapplicable",
        "requires_permission",
        "unavailable",
        "invalid"
      ],
      "title": "SkillApplicabilityStatus",
      "type": "string"
    },
    "SkillPreconditionResult": {
      "additionalProperties": false,
      "properties": {
        "evidence_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Hash",
          "type": "string"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "precondition_id": {
          "minLength": 1,
          "title": "Precondition Id",
          "type": "string"
        },
        "reason_code": {
          "minLength": 1,
          "title": "Reason Code",
          "type": "string"
        }
      },
      "required": [
        "precondition_id",
        "passed",
        "reason_code",
        "evidence_hash"
      ],
      "title": "SkillPreconditionResult",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/skills/skill-selection-candidate.schema.json",
  "additionalProperties": false,
  "properties": {
    "applicability": {
      "$ref": "#/$defs/SkillApplicabilityResult"
    },
    "estimated_context_tokens": {
      "minimum": 0,
      "title": "Estimated Context Tokens",
      "type": "integer"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "safety_penalty": {
      "minimum": 0,
      "title": "Safety Penalty",
      "type": "integer"
    },
    "scope_score": {
      "minimum": 0,
      "title": "Scope Score",
      "type": "integer"
    },
    "skill_id": {
      "format": "uuid",
      "title": "Skill Id",
      "type": "string"
    },
    "specificity_score": {
      "minimum": 0,
      "title": "Specificity Score",
      "type": "integer"
    },
    "statistics_score": {
      "minimum": 0,
      "title": "Statistics Score",
      "type": "integer"
    }
  },
  "required": [
    "skill_id",
    "revision",
    "applicability",
    "specificity_score",
    "scope_score",
    "statistics_score",
    "safety_penalty",
    "estimated_context_tokens"
  ],
  "title": "SkillSelectionCandidate",
  "type": "object"
}
