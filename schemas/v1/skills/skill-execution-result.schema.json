{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "SkillExecutionStatus": {
      "enum": [
        "preparing",
        "running",
        "waiting",
        "accepted",
        "rejected",
        "unverifiable",
        "failed",
        "cancelled"
      ],
      "title": "SkillExecutionStatus",
      "type": "string"
    },
    "SkillExecutionStepResult": {
      "additionalProperties": false,
      "properties": {
        "output_artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Output Artifacts",
          "type": "array"
        },
        "provider_call_ids": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Provider Call Ids",
          "type": "array"
        },
        "reason": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "status": {
          "$ref": "#/$defs/SkillExecutionStatus"
        },
        "step_id": {
          "minLength": 1,
          "title": "Step Id",
          "type": "string"
        },
        "tool_call_ids": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Tool Call Ids",
          "type": "array"
        },
        "verifier_result_ids": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Verifier Result Ids",
          "type": "array"
        }
      },
      "required": [
        "step_id",
        "status"
      ],
      "title": "SkillExecutionStepResult",
      "type": "object"
    },
    "TokenUsage": {
      "additionalProperties": false,
      "properties": {
        "cached_input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cached Input Tokens"
        },
        "input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "output_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "reasoning_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Tokens"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        }
      },
      "title": "TokenUsage",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/skills/skill-execution-result.schema.json",
  "additionalProperties": false,
  "properties": {
    "acceptance_decision_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Acceptance Decision Id"
    },
    "artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "execution_id": {
      "format": "uuid",
      "title": "Execution Id",
      "type": "string"
    },
    "failure": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Failure"
    },
    "fallback_execution_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fallback Execution Id"
    },
    "finished_at": {
      "format": "date-time",
      "title": "Finished At",
      "type": "string"
    },
    "result_hash": {
      "default": "",
      "title": "Result Hash",
      "type": "string"
    },
    "skill_id": {
      "format": "uuid",
      "title": "Skill Id",
      "type": "string"
    },
    "skill_revision": {
      "minimum": 1,
      "title": "Skill Revision",
      "type": "integer"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/SkillExecutionStatus"
    },
    "step_results": {
      "items": {
        "$ref": "#/$defs/SkillExecutionStepResult"
      },
      "title": "Step Results",
      "type": "array"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    },
    "usage": {
      "$ref": "#/$defs/TokenUsage",
      "default": {
        "cached_input_tokens": null,
        "input_tokens": null,
        "output_tokens": null,
        "reasoning_tokens": null,
        "total_tokens": null
      }
    },
    "verification_bundle": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "warnings": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "execution_id",
    "skill_id",
    "skill_revision",
    "task_run_id",
    "status",
    "step_results",
    "started_at",
    "finished_at"
  ],
  "title": "SkillExecutionResult",
  "type": "object"
}
