{
  "$defs": {
    "MemorySensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "MemorySensitivity",
      "type": "string"
    },
    "SkillAccessType": {
      "enum": [
        "registry_query",
        "context_retrieval",
        "summary_hydration",
        "full_hydration",
        "resource_hydration",
        "selection",
        "execution",
        "export"
      ],
      "title": "SkillAccessType",
      "type": "string"
    },
    "SkillScope": {
      "additionalProperties": false,
      "properties": {
        "scope_id": {
          "minLength": 1,
          "title": "Scope Id",
          "type": "string"
        },
        "scope_type": {
          "$ref": "#/$defs/SkillScopeType"
        }
      },
      "required": [
        "scope_type",
        "scope_id"
      ],
      "title": "SkillScope",
      "type": "object"
    },
    "SkillScopeType": {
      "enum": [
        "global",
        "project",
        "repository",
        "domain",
        "provider"
      ],
      "title": "SkillScopeType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/skills/skill-access-record.schema.json",
  "additionalProperties": false,
  "properties": {
    "access_id": {
      "format": "uuid",
      "title": "Access Id",
      "type": "string"
    },
    "access_type": {
      "$ref": "#/$defs/SkillAccessType"
    },
    "accessed_at": {
      "format": "date-time",
      "title": "Accessed At",
      "type": "string"
    },
    "context_request_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Context Request Id"
    },
    "query_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Query Hash"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "scope": {
      "$ref": "#/$defs/SkillScope"
    },
    "sensitivity": {
      "$ref": "#/$defs/MemorySensitivity"
    },
    "skill_id": {
      "format": "uuid",
      "title": "Skill Id",
      "type": "string"
    },
    "task_run_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Run Id"
    }
  },
  "required": [
    "access_id",
    "skill_id",
    "revision",
    "access_type",
    "scope",
    "sensitivity",
    "accessed_at"
  ],
  "title": "SkillAccessRecord",
  "type": "object"
}
