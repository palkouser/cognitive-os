{
  "$defs": {
    "SkillPackageFile": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "file_type": {
          "$ref": "#/$defs/SkillPackageFileType"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "size_bytes": {
          "maximum": 2097152,
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "relative_path",
        "file_type",
        "media_type",
        "size_bytes",
        "content_hash"
      ],
      "title": "SkillPackageFile",
      "type": "object"
    },
    "SkillPackageFileType": {
      "enum": [
        "instructions",
        "metadata",
        "resource",
        "template",
        "script",
        "test"
      ],
      "title": "SkillPackageFileType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/skills/skill-package-manifest.schema.json",
  "additionalProperties": false,
  "properties": {
    "files": {
      "items": {
        "$ref": "#/$defs/SkillPackageFile"
      },
      "maxItems": 256,
      "minItems": 2,
      "title": "Files",
      "type": "array"
    },
    "format_version": {
      "default": "1",
      "pattern": "^1$",
      "title": "Format Version",
      "type": "string"
    },
    "package_hash": {
      "default": "",
      "title": "Package Hash",
      "type": "string"
    },
    "total_bytes": {
      "maximum": 16777216,
      "minimum": 1,
      "title": "Total Bytes",
      "type": "integer"
    }
  },
  "required": [
    "files",
    "total_bytes"
  ],
  "title": "SkillPackageManifest",
  "type": "object"
}
