{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "SkillExecutionStatus": {
      "enum": [
        "preparing",
        "running",
        "waiting",
        "accepted",
        "rejected",
        "unverifiable",
        "failed",
        "cancelled"
      ],
      "title": "SkillExecutionStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/skills/skill-execution-step-result.schema.json",
  "additionalProperties": false,
  "properties": {
    "output_artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Output Artifacts",
      "type": "array"
    },
    "provider_call_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Provider Call Ids",
      "type": "array"
    },
    "reason": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reason"
    },
    "status": {
      "$ref": "#/$defs/SkillExecutionStatus"
    },
    "step_id": {
      "minLength": 1,
      "title": "Step Id",
      "type": "string"
    },
    "tool_call_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Tool Call Ids",
      "type": "array"
    },
    "verifier_result_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Verifier Result Ids",
      "type": "array"
    }
  },
  "required": [
    "step_id",
    "status"
  ],
  "title": "SkillExecutionStepResult",
  "type": "object"
}
