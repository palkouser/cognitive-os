{
  "$defs": {
    "ImpactDimension": {
      "enum": [
        "frequency",
        "affected_task_count",
        "severity",
        "safety_impact",
        "correctness_impact",
        "user_correction_count",
        "cost_impact",
        "latency_impact",
        "repair_iteration_impact",
        "recency",
        "reproducibility",
        "evidence_confidence",
        "strategic_reach"
      ],
      "title": "ImpactDimension",
      "type": "string"
    },
    "ImpactDimensionResult": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "dimension": {
          "$ref": "#/$defs/ImpactDimension"
        },
        "normalized_value": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Normalized Value",
          "type": "string"
        },
        "profile_version": {
          "exclusiveMinimum": 0,
          "title": "Profile Version",
          "type": "integer"
        },
        "raw_value": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Raw Value",
          "type": "string"
        },
        "sample_count": {
          "minimum": 0,
          "title": "Sample Count",
          "type": "integer"
        },
        "source_refs": {
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "uncertainty": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Uncertainty",
          "type": "string"
        },
        "weight": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Weight",
          "type": "string"
        },
        "weighted_value": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Weighted Value",
          "type": "string"
        }
      },
      "required": [
        "dimension",
        "raw_value",
        "normalized_value",
        "weight",
        "weighted_value",
        "source_refs",
        "sample_count",
        "uncertainty",
        "profile_version"
      ],
      "title": "ImpactDimensionResult",
      "type": "object"
    },
    "ImpactProfileReference": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "critical_safety_priority_floor": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Critical Safety Priority Floor",
          "type": "string"
        },
        "high_correctness_priority_floor": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "High Correctness Priority Floor",
          "type": "string"
        },
        "profile_id": {
          "minLength": 1,
          "title": "Profile Id",
          "type": "string"
        },
        "score_precision": {
          "default": 4,
          "maximum": 8,
          "minimum": 0,
          "title": "Score Precision",
          "type": "integer"
        },
        "version": {
          "exclusiveMinimum": 0,
          "title": "Version",
          "type": "integer"
        },
        "weights": {
          "additionalProperties": {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "type": "string"
          },
          "propertyNames": {
            "$ref": "#/$defs/ImpactDimension"
          },
          "title": "Weights",
          "type": "object"
        }
      },
      "required": [
        "profile_id",
        "version",
        "weights",
        "critical_safety_priority_floor",
        "high_correctness_priority_floor"
      ],
      "title": "ImpactProfileReference",
      "type": "object"
    },
    "ImpactScore": {
      "additionalProperties": false,
      "properties": {
        "base_score": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Base Score",
          "type": "string"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "dimensions": {
          "items": {
            "$ref": "#/$defs/ImpactDimensionResult"
          },
          "maxItems": 13,
          "minItems": 13,
          "title": "Dimensions",
          "type": "array"
        },
        "final_score": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Final Score",
          "type": "string"
        },
        "group_snapshot_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Group Snapshot Hash",
          "type": "string"
        },
        "impact_score_id": {
          "format": "uuid",
          "title": "Impact Score Id",
          "type": "string"
        },
        "limitations": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "priority": {
          "$ref": "#/$defs/WeaknessPriority"
        },
        "priority_floor": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Priority Floor",
          "type": "string"
        },
        "profile": {
          "$ref": "#/$defs/ImpactProfileReference"
        },
        "uncertainty": {
          "$ref": "#/$defs/ImpactUncertainty"
        },
        "weakness_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Weakness Id"
        },
        "weakness_revision": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Weakness Revision"
        }
      },
      "required": [
        "impact_score_id",
        "group_snapshot_hash",
        "dimensions",
        "base_score",
        "priority_floor",
        "final_score",
        "priority",
        "uncertainty",
        "profile",
        "created_at"
      ],
      "title": "ImpactScore",
      "type": "object"
    },
    "ImpactUncertainty": {
      "additionalProperties": false,
      "properties": {
        "conflict_count": {
          "minimum": 0,
          "title": "Conflict Count",
          "type": "integer"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "counterexample_count": {
          "minimum": 0,
          "title": "Counterexample Count",
          "type": "integer"
        },
        "limitations": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "missing_source_count": {
          "minimum": 0,
          "title": "Missing Source Count",
          "type": "integer"
        },
        "value": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "value",
        "missing_source_count",
        "conflict_count",
        "counterexample_count"
      ],
      "title": "ImpactUncertainty",
      "type": "object"
    },
    "MemorySensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "MemorySensitivity",
      "type": "string"
    },
    "MiningSourceReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "authoritative": {
          "default": true,
          "title": "Authoritative",
          "type": "boolean"
        },
        "contains_secret": {
          "default": false,
          "title": "Contains Secret",
          "type": "boolean"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "event_stream_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Stream Id"
        },
        "event_stream_version": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Stream Version"
        },
        "outcome_authority": {
          "default": false,
          "title": "Outcome Authority",
          "type": "boolean"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "scope": {
          "minLength": 1,
          "title": "Scope",
          "type": "string"
        },
        "sensitivity": {
          "$ref": "#/$defs/MemorySensitivity"
        },
        "shadow": {
          "default": false,
          "title": "Shadow",
          "type": "boolean"
        },
        "source_content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Content Hash",
          "type": "string"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_revision": {
          "minLength": 1,
          "title": "Source Revision",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/SignalSourceType"
        }
      },
      "required": [
        "source_type",
        "source_id",
        "source_revision",
        "source_content_hash",
        "scope",
        "sensitivity"
      ],
      "title": "MiningSourceReference",
      "type": "object"
    },
    "NextAnalysisType": {
      "enum": [
        "collect_more_evidence",
        "run_bounded_replay",
        "create_benchmark_candidate",
        "inspect_context_trace",
        "inspect_retrieval",
        "inspect_verifier",
        "inspect_routing",
        "inspect_skill",
        "inspect_strategy",
        "inspect_provider_or_tool",
        "operator_review",
        "monitor",
        "none"
      ],
      "title": "NextAnalysisType",
      "type": "string"
    },
    "QueueBlockerType": {
      "enum": [
        "requires_more_evidence",
        "requires_reproduction",
        "depends_on_other_weakness",
        "requires_operator_review",
        "source_unavailable",
        "sensitivity_restriction"
      ],
      "title": "QueueBlockerType",
      "type": "string"
    },
    "SignalSourceType": {
      "enum": [
        "controller",
        "acceptance",
        "verifier",
        "user_correction",
        "context",
        "retrieval",
        "provider_request",
        "provider_result",
        "tool",
        "memory",
        "semantic",
        "skill",
        "strategy",
        "experience",
        "corpus",
        "routing_decision",
        "routing_outcome",
        "routing_shadow",
        "benchmark",
        "artifact"
      ],
      "title": "SignalSourceType",
      "type": "string"
    },
    "WeaknessBenchmarkCandidate": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "format": "uuid",
          "title": "Candidate Id",
          "type": "string"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "expected_outcome_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Expected Outcome Hash",
          "type": "string"
        },
        "forbidden_operations": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Forbidden Operations",
          "type": "array"
        },
        "proposal_only": {
          "default": true,
          "title": "Proposal Only",
          "type": "boolean"
        },
        "required_verifiers": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Verifiers",
          "type": "array"
        },
        "sensitivity": {
          "$ref": "#/$defs/MemorySensitivity"
        },
        "task_fixture_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Task Fixture Hash",
          "type": "string"
        },
        "weakness_revision_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Weakness Revision Hash",
          "type": "string"
        }
      },
      "required": [
        "candidate_id",
        "weakness_revision_hash",
        "task_fixture_hash",
        "expected_outcome_hash",
        "required_verifiers",
        "forbidden_operations",
        "sensitivity"
      ],
      "title": "WeaknessBenchmarkCandidate",
      "type": "object"
    },
    "WeaknessEvidencePackage": {
      "additionalProperties": false,
      "properties": {
        "artifact_reference": {
          "format": "uuid",
          "title": "Artifact Reference",
          "type": "string"
        },
        "artifact_refs": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Artifact Refs",
          "type": "array"
        },
        "checksums": {
          "additionalProperties": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "propertyNames": {
            "minLength": 1
          },
          "title": "Checksums",
          "type": "object"
        },
        "complete_source_count": {
          "exclusiveMinimum": 0,
          "title": "Complete Source Count",
          "type": "integer"
        },
        "component_sections": {
          "additionalProperties": {
            "items": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "type": "array"
          },
          "propertyNames": {
            "minLength": 1
          },
          "title": "Component Sections",
          "type": "object"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "counterexample_hashes": {
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Counterexample Hashes",
          "type": "array"
        },
        "event_refs": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Event Refs",
          "type": "array"
        },
        "evidence_package_id": {
          "format": "uuid",
          "title": "Evidence Package Id",
          "type": "string"
        },
        "group_snapshot_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Group Snapshot Hash",
          "type": "string"
        },
        "limitations": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "representative_signal_hashes": {
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Representative Signal Hashes",
          "type": "array"
        },
        "reproduction": {
          "$ref": "#/$defs/WeaknessReproductionAssessment"
        },
        "sensitivity": {
          "$ref": "#/$defs/MemorySensitivity"
        },
        "source_manifest": {
          "items": {
            "$ref": "#/$defs/MiningSourceReference"
          },
          "title": "Source Manifest",
          "type": "array"
        },
        "task_refs": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Task Refs",
          "type": "array"
        },
        "verification_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Verification Hash",
          "type": "string"
        },
        "weakness_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Weakness Id"
        },
        "weakness_revision": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Weakness Revision"
        }
      },
      "required": [
        "evidence_package_id",
        "group_snapshot_hash",
        "source_manifest",
        "representative_signal_hashes",
        "complete_source_count",
        "counterexample_hashes",
        "task_refs",
        "event_refs",
        "artifact_refs",
        "component_sections",
        "reproduction",
        "sensitivity",
        "limitations",
        "artifact_reference",
        "checksums",
        "verification_hash"
      ],
      "title": "WeaknessEvidencePackage",
      "type": "object"
    },
    "WeaknessPriority": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational"
      ],
      "title": "WeaknessPriority",
      "type": "string"
    },
    "WeaknessQueueDependency": {
      "additionalProperties": false,
      "properties": {
        "blocked_by_weakness_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Blocked By Weakness Id"
        },
        "blocker_type": {
          "$ref": "#/$defs/QueueBlockerType"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "evidence_reference": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Reference",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "blocker_type",
        "evidence_reference",
        "reason"
      ],
      "title": "WeaknessQueueDependency",
      "type": "object"
    },
    "WeaknessQueueEntry": {
      "additionalProperties": false,
      "properties": {
        "blocked_by": {
          "items": {
            "$ref": "#/$defs/WeaknessQueueDependency"
          },
          "title": "Blocked By",
          "type": "array"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "priority": {
          "$ref": "#/$defs/WeaknessPriority"
        },
        "priority_reason": {
          "minLength": 1,
          "title": "Priority Reason",
          "type": "string"
        },
        "queue_entry_id": {
          "format": "uuid",
          "title": "Queue Entry Id",
          "type": "string"
        },
        "queue_policy_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Queue Policy Hash",
          "type": "string"
        },
        "recommended_next_analysis": {
          "$ref": "#/$defs/NextAnalysisType"
        },
        "status": {
          "$ref": "#/$defs/WeaknessQueueStatus"
        },
        "weakness_id": {
          "format": "uuid",
          "title": "Weakness Id",
          "type": "string"
        },
        "weakness_revision": {
          "exclusiveMinimum": 0,
          "title": "Weakness Revision",
          "type": "integer"
        },
        "weakness_revision_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Weakness Revision Hash",
          "type": "string"
        },
        "weakness_status": {
          "$ref": "#/$defs/WeaknessStatus"
        }
      },
      "required": [
        "queue_entry_id",
        "weakness_id",
        "weakness_revision",
        "weakness_revision_hash",
        "weakness_status",
        "priority",
        "priority_reason",
        "blocked_by",
        "recommended_next_analysis",
        "status",
        "queue_policy_hash",
        "created_at"
      ],
      "title": "WeaknessQueueEntry",
      "type": "object"
    },
    "WeaknessQueueStatus": {
      "enum": [
        "queued",
        "blocked",
        "deferred",
        "monitoring",
        "removed",
        "superseded"
      ],
      "title": "WeaknessQueueStatus",
      "type": "string"
    },
    "WeaknessReplayCandidate": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "format": "uuid",
          "title": "Candidate Id",
          "type": "string"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "expected_result_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Expected Result Hash",
          "type": "string"
        },
        "proposal_only": {
          "default": true,
          "title": "Proposal Only",
          "type": "boolean"
        },
        "request_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Request Hash",
          "type": "string"
        },
        "source_snapshot_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Snapshot Hash",
          "type": "string"
        },
        "weakness_revision_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Weakness Revision Hash",
          "type": "string"
        }
      },
      "required": [
        "candidate_id",
        "weakness_revision_hash",
        "source_snapshot_hash",
        "request_hash",
        "expected_result_hash"
      ],
      "title": "WeaknessReplayCandidate",
      "type": "object"
    },
    "WeaknessReproductionAssessment": {
      "additionalProperties": false,
      "properties": {
        "assessed_at": {
          "format": "date-time",
          "title": "Assessed At",
          "type": "string"
        },
        "attempts": {
          "items": {
            "$ref": "#/$defs/WeaknessReproductionAttempt"
          },
          "title": "Attempts",
          "type": "array"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "limitations": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "required_safety_restrictions": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Safety Restrictions",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/WeaknessReproductionStatus"
        }
      },
      "required": [
        "status",
        "attempts",
        "required_safety_restrictions",
        "limitations",
        "assessed_at"
      ],
      "title": "WeaknessReproductionAssessment",
      "type": "object"
    },
    "WeaknessReproductionAttempt": {
