{
  "$defs": {
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/proposals/proposal-verification-subject.schema.json",
  "additionalProperties": false,
  "properties": {
    "bounded_metadata": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "propertyNames": {
        "minLength": 1
      },
      "title": "Bounded Metadata",
      "type": "object"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "proposal_id": {
      "format": "uuid",
      "title": "Proposal Id",
      "type": "string"
    },
    "proposal_revision": {
      "exclusiveMinimum": 0,
      "title": "Proposal Revision",
      "type": "integer"
    },
    "subject_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Subject Hash",
      "type": "string"
    },
    "subject_type": {
      "minLength": 1,
      "title": "Subject Type",
      "type": "string"
    }
