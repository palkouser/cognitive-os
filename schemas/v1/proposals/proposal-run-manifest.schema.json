{
  "$id": "https://cognitive-os.local/schemas/v1/proposals/proposal-run-manifest.schema.json",
  "additionalProperties": false,
  "properties": {
    "artifact_hashes": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Artifact Hashes",
      "type": "array"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "no_destination_writes": {
      "const": true,
      "default": true,
      "title": "No Destination Writes",
      "type": "boolean"
    },
    "policy_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Policy Hash",
      "type": "string"
    },
    "proposal_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Proposal Hash",
      "type": "string"
    },
    "proposal_id": {
      "format": "uuid",
      "title": "Proposal Id",
      "type": "string"
    },
    "proposal_revision": {
      "exclusiveMinimum": 0,
      "title": "Proposal Revision",
      "type": "integer"
    },
    "registry_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Registry Hash",
      "type": "string"
    },
    "source_snapshot_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Source Snapshot Hash",
      "type": "string"
    },
    "verifier_bundle_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Verifier Bundle Hash",
      "type": "string"
    }
  },
  "required": [
    "proposal_id",
    "proposal_revision",
    "source_snapshot_hash",
    "registry_hash",
    "policy_hash",
    "proposal_hash",
    "verifier_bundle_hash",
    "artifact_hashes",
    "created_at"
  ],
  "title": "ProposalRunManifest",
  "type": "object"
}
