{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ErrorInfo": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Details",
          "type": "object"
        },
        "error_type": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Type"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ErrorInfo",
      "type": "object"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "WorkspaceDisposition": {
      "enum": [
        "remove",
        "archive",
        "preserve_for_review",
        "preserve_after_failure"
      ],
      "title": "WorkspaceDisposition",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/workspace-cleanup-result.schema.json",
  "additionalProperties": false,
  "properties": {
    "archive_artifact": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "completed": {
      "title": "Completed",
      "type": "boolean"
    },
    "disposition": {
      "$ref": "#/$defs/WorkspaceDisposition"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorInfo"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "workspace_id": {
      "format": "uuid",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "workspace_id",
    "disposition",
    "completed"
  ],
  "title": "WorkspaceCleanupResult",
  "type": "object"
}
