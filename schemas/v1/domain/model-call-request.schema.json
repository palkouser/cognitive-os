{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "CallStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "timed_out"
      ],
      "title": "CallStatus",
      "type": "string"
    },
    "ModelParameters": {
      "additionalProperties": false,
      "properties": {
        "context_budget": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Context Budget"
        },
        "max_output_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Output Tokens"
        },
        "structured_output_schema_name": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Structured Output Schema Name"
        },
        "temperature": {
          "anyOf": [
            {
              "maximum": 2,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        },
        "timeout_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeout Seconds"
        },
        "tool_choice": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Choice"
        }
      },
      "title": "ModelParameters",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/model-call-request.schema.json",
  "additionalProperties": false,
  "properties": {
    "input_artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Input Artifacts",
      "type": "array"
    },
    "model_call_id": {
      "format": "uuid",
      "title": "Model Call Id",
      "type": "string"
    },
    "parameters": {
      "$ref": "#/$defs/ModelParameters",
      "default": {
        "context_budget": null,
        "max_output_tokens": null,
        "structured_output_schema_name": null,
        "temperature": null,
        "timeout_seconds": null,
        "tool_choice": null
      }
    },
    "provider": {
      "minLength": 1,
      "title": "Provider",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "requested_model": {
      "minLength": 1,
      "title": "Requested Model",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/CallStatus",
      "default": "pending"
    },
    "step_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Step Id"
    },
    "system_context_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "System Context Hash"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    }
  },
  "required": [
    "model_call_id",
    "task_run_id",
    "provider",
    "requested_model",
    "requested_at"
  ],
  "title": "ModelCallRequestRecord",
  "type": "object"
}
