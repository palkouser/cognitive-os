{
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/ActorType"
        },
        "display_name": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ActorType": {
      "enum": [
        "user",
        "agent",
        "model",
        "tool",
        "verifier",
        "system"
      ],
      "title": "ActorType",
      "type": "string"
    },
    "ControllerActionType": {
      "enum": [
        "provider",
        "tool",
        "verification",
        "manual"
      ],
      "title": "ControllerActionType",
      "type": "string"
    },
    "ControllerStepAction": {
      "additionalProperties": false,
      "properties": {
        "action_type": {
          "$ref": "#/$defs/ControllerActionType"
        },
        "expected_artifacts": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Expected Artifacts",
          "type": "array"
        },
        "provider_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Id"
        },
        "provider_instructions": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Instructions"
        },
        "requested_model": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested Model"
        },
        "response_format": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Response Format"
        },
        "response_schema": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Response Schema"
        },
        "step_id": {
          "format": "uuid",
          "title": "Step Id",
          "type": "string"
        },
        "tool_arguments": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Arguments"
        },
        "tool_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Id"
        },
        "tool_version": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Version"
        },
        "verifier_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Verifier Ids",
          "type": "array"
        }
      },
      "required": [
        "step_id",
        "action_type"
      ],
      "title": "ControllerStepAction",
      "type": "object"
    },
    "ExecutionPlan": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "created_by": {
          "$ref": "#/$defs/ActorRef"
        },
        "plan_id": {
          "format": "uuid",
          "title": "Plan Id",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/PlanStepDefinition"
          },
          "minItems": 1,
          "title": "Steps",
          "type": "array"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "plan_id",
        "task_run_id",
        "version",
        "created_at",
        "created_by",
        "steps"
      ],
      "title": "ExecutionPlan",
      "type": "object"
    },
    "PlanStepDefinition": {
      "additionalProperties": false,
      "properties": {
        "depends_on": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "expected_output": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Output"
        },
        "required_tool_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Tool Ids",
          "type": "array"
        },
        "required_verifier_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Verifier Ids",
          "type": "array"
        },
        "sequence": {
          "minimum": 1,
          "title": "Sequence",
          "type": "integer"
        },
        "step_id": {
          "format": "uuid",
          "title": "Step Id",
          "type": "string"
        },
        "step_type": {
          "minLength": 1,
          "title": "Step Type",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "step_id",
        "sequence",
        "step_type",
        "title"
      ],
      "title": "PlanStepDefinition",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/controller-execution-plan.schema.json",
  "additionalProperties": false,
  "properties": {
    "actions": {
      "items": {
        "$ref": "#/$defs/ControllerStepAction"
      },
      "minItems": 1,
      "title": "Actions",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "plan": {
      "$ref": "#/$defs/ExecutionPlan"
    },
    "sequential_only": {
      "default": true,
      "title": "Sequential Only",
      "type": "boolean"
    }
  },
  "required": [
    "plan",
    "actions",
    "created_at",
    "created_by"
  ],
  "title": "ControllerExecutionPlan",
  "type": "object"
}
