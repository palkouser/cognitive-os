        "$ref": "#/$defs/CodingCommandReport"
      },
      "title": "Command Reports",
      "type": "array"
    },
    "context_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Context Hash",
      "type": "string"
    },
    "final_diff": {
      "anyOf": [
        {
          "$ref": "#/$defs/UnifiedDiffArtifact"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "patch_attempts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PatchAttempt"
      },
      "title": "Patch Attempts",
      "type": "array"
    },
    "patch_plan": {
      "anyOf": [
        {
          "$ref": "#/$defs/CodingPatchPlan"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "problem": {
      "$ref": "#/$defs/CodingProblemExtension"
    },
    "provenance": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Provenance",
      "type": "object"
    },
    "repair_decisions": {
      "default": [],
      "items": {
        "additionalProperties": {
          "$ref": "#/$defs/JsonValue"
        },
        "type": "object"
      },
      "title": "Repair Decisions",
      "type": "array"
    },
    "repository_profile": {
      "$ref": "#/$defs/RepositoryProfile"
    },
    "risks": {
      "default": [],
      "items": {
        "$ref": "#/$defs/RiskRecord"
      },
      "title": "Risks",
      "type": "array"
    },
    "usage_metrics": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Usage Metrics",
      "type": "object"
    },
    "verifier_failures": {
      "default": [],
      "items": {
        "additionalProperties": {
          "$ref": "#/$defs/JsonValue"
        },
        "type": "object"
      },
      "title": "Verifier Failures",
      "type": "array"
    }
  },
  "required": [
    "problem",
