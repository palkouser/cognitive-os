{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ErrorInfo": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Details",
          "type": "object"
        },
        "error_type": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Type"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ErrorInfo",
      "type": "object"
    },
    "FindingSeverity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "FindingSeverity",
      "type": "string"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "VerificationBundle": {
      "additionalProperties": false,
      "properties": {
        "bundle_id": {
          "format": "uuid",
          "title": "Bundle Id",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "criterion_results": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Criterion Results",
          "type": "array"
        },
        "errored_required_criteria": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Errored Required Criteria",
          "type": "array"
        },
        "failed_required_criteria": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Failed Required Criteria",
          "type": "array"
        },
        "optional_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Optional Score",
          "type": "number"
        },
        "required_passed": {
          "title": "Required Passed",
          "type": "boolean"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        },
        "unverifiable_required_criteria": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Unverifiable Required Criteria",
          "type": "array"
        },
        "verifier_results": {
          "items": {
            "$ref": "#/$defs/VerifierResult"
          },
          "title": "Verifier Results",
          "type": "array"
        }
      },
      "required": [
        "bundle_id",
        "task_run_id",
        "criterion_results",
        "verifier_results",
        "required_passed",
        "optional_score",
        "created_at"
      ],
      "title": "VerificationBundle",
      "type": "object"
    },
    "VerificationSubjectRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "subject_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subject Id"
        },
        "subject_type": {
          "minLength": 1,
          "title": "Subject Type",
          "type": "string"
        }
      },
      "required": [
        "subject_type"
      ],
      "title": "VerificationSubjectRef",
      "type": "object"
    },
    "VerifierFinding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "evidence_artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Evidence Artifacts",
          "type": "array"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/FindingSeverity"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "VerifierFinding",
      "type": "object"
    },
    "VerifierResult": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence_artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Evidence Artifacts",
          "type": "array"
        },
        "findings": {
          "default": [],
          "items": {
            "$ref": "#/$defs/VerifierFinding"
          },
          "title": "Findings",
          "type": "array"
        },
        "finished_at": {
          "format": "date-time",
          "title": "Finished At",
          "type": "string"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/VerifierStatus"
        },
        "subject": {
          "$ref": "#/$defs/VerificationSubjectRef"
        },
        "verifier_id": {
          "minLength": 1,
          "title": "Verifier Id",
          "type": "string"
        },
        "verifier_result_id": {
          "format": "uuid",
          "title": "Verifier Result Id",
          "type": "string"
        },
        "verifier_version": {
          "minLength": 1,
          "title": "Verifier Version",
          "type": "string"
        }
      },
      "required": [
        "verifier_result_id",
        "verifier_id",
        "verifier_version",
        "subject",
        "status",
        "started_at",
        "finished_at"
      ],
      "title": "VerifierResult",
      "type": "object"
    },
    "VerifierStatus": {
      "enum": [
        "passed",
        "failed",
        "partial",
        "unverifiable",
        "error"
      ],
      "title": "VerifierStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/coding-verification-summary.schema.json",
  "additionalProperties": false,
  "properties": {
    "focused_bundles": {
      "default": [],
      "items": {
        "$ref": "#/$defs/VerificationBundle"
      },
      "title": "Focused Bundles",
      "type": "array"
    },
    "full_bundle": {
      "anyOf": [
        {
          "$ref": "#/$defs/VerificationBundle"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "registry_snapshot_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Registry Snapshot Hash",
      "type": "string"
    },
    "required_criteria_resolved": {
      "title": "Required Criteria Resolved",
      "type": "boolean"
    }
  },
  "required": [
    "registry_snapshot_hash",
    "required_criteria_resolved"
  ],
  "title": "CodingVerificationSummary",
  "type": "object"
}
