          "title": "Optional Score",
          "type": "number"
        },
        "policy_id": {
          "format": "uuid",
          "title": "Policy Id",
          "type": "string"
        },
        "policy_version": {
          "minLength": 1,
          "title": "Policy Version",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "required_passed": {
          "title": "Required Passed",
          "type": "boolean"
