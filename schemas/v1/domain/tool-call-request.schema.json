{
  "$defs": {
    "CallStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "timed_out"
      ],
      "title": "CallStatus",
      "type": "string"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "PermissionDecision": {
      "enum": [
        "not_required",
        "pending",
        "allowed",
        "denied"
      ],
      "title": "PermissionDecision",
      "type": "string"
    },
    "RiskLevel": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "RiskLevel",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/tool-call-request.schema.json",
  "additionalProperties": false,
  "properties": {
    "arguments": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Arguments",
      "type": "object"
    },
    "permission_decision": {
      "$ref": "#/$defs/PermissionDecision",
      "default": "not_required"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "risk_level": {
      "$ref": "#/$defs/RiskLevel",
      "default": "low"
    },
    "status": {
      "$ref": "#/$defs/CallStatus",
      "default": "pending"
    },
    "step_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Step Id"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    },
    "tool_call_id": {
      "format": "uuid",
      "title": "Tool Call Id",
      "type": "string"
    },
    "tool_id": {
      "minLength": 1,
      "title": "Tool Id",
      "type": "string"
    },
    "tool_version": {
      "minLength": 1,
      "title": "Tool Version",
      "type": "string"
    }
  },
  "required": [
    "tool_call_id",
    "task_run_id",
    "tool_id",
    "tool_version",
    "requested_at"
  ],
  "title": "ToolCallRequestRecord",
  "type": "object"
}
