{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "VerificationSubjectType": {
      "enum": [
        "structured_value",
        "artifact",
        "workspace",
        "execution_plan",
        "execution_step",
        "model_response",
        "tool_result",
        "mathematical_expression",
        "logical_problem",
        "physical_quantity",
        "semantic_snapshot",
        "context_bundle",
        "skill_package",
        "skill_revision",
        "skill_execution",
        "skill_regression",
        "strategy_revision",
        "strategy_graph",
        "strategy_plan",
        "strategy_outcome",
        "strategy_statistics"
      ],
      "title": "VerificationSubjectType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/verification-subject.schema.json",
  "additionalProperties": false,
  "properties": {
    "artifact_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "inline_value": {
      "$ref": "#/$defs/JsonValue",
      "default": null
    },
    "source_event_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Source Event Ids",
      "type": "array"
    },
    "subject_type": {
      "$ref": "#/$defs/VerificationSubjectType"
    },
    "workspace_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Workspace Path"
    }
  },
  "required": [
    "subject_type"
  ],
  "title": "VerificationSubject",
  "type": "object"
}
