{
  "$defs": {
    "AcceptanceDecision": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "criterion_evaluations": {
          "items": {
            "$ref": "#/$defs/CriterionEvaluation"
          },
          "title": "Criterion Evaluations",
          "type": "array"
        },
        "decision": {
          "$ref": "#/$defs/AcceptanceDecisionType"
        },
        "decision_id": {
          "format": "uuid",
          "title": "Decision Id",
          "type": "string"
        },
        "optional_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Optional Score",
          "type": "number"
        },
        "policy_id": {
          "format": "uuid",
          "title": "Policy Id",
          "type": "string"
        },
        "policy_version": {
          "minLength": 1,
          "title": "Policy Version",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "required_passed": {
          "title": "Required Passed",
          "type": "boolean"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        }
      },
      "required": [
        "decision_id",
        "task_run_id",
        "policy_id",
        "policy_version",
        "decision",
        "criterion_evaluations",
        "required_passed",
        "optional_score",
        "reason",
        "created_at"
      ],
      "title": "AcceptanceDecision",
      "type": "object"
    },
    "AcceptanceDecisionType": {
      "enum": [
        "accepted",
        "rejected",
        "needs_repair",
        "needs_clarification",
        "unverifiable",
        "verification_error"
      ],
      "title": "AcceptanceDecisionType",
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "BenchmarkCaseResult": {
      "additionalProperties": false,
      "properties": {
        "acceptance_decision": {
          "anyOf": [
            {
              "$ref": "#/$defs/AcceptanceDecision"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "artifact_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Artifact Refs",
          "type": "array"
        },
        "case_id": {
          "minLength": 1,
          "title": "Case Id",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "finished_at": {
          "format": "date-time",
          "title": "Finished At",
          "type": "string"
        },
        "metrics": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Metrics",
          "type": "object"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/BenchmarkCaseStatus"
        },
        "task_run_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Run Id"
        },
        "verifier_bundles": {
          "default": [],
          "items": {
            "$ref": "#/$defs/VerificationBundle"
          },
          "title": "Verifier Bundles",
          "type": "array"
        }
      },
      "required": [
        "case_id",
        "status",
        "started_at",
        "finished_at"
      ],
      "title": "BenchmarkCaseResult",
      "type": "object"
    },
    "BenchmarkCaseStatus": {
      "enum": [
        "pending",
        "running",
        "passed",
        "failed",
        "skipped",
        "error",
        "timed_out"
      ],
      "title": "BenchmarkCaseStatus",
      "type": "string"
    },
    "BenchmarkRunStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled"
      ],
      "title": "BenchmarkRunStatus",
      "type": "string"
    },
    "CriterionEvaluation": {
      "additionalProperties": false,
      "properties": {
        "criterion_id": {
          "format": "uuid",
          "title": "Criterion Id",
          "type": "string"
        },
        "outcome": {
          "$ref": "#/$defs/VerifierStatus"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "result_ids": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Result Ids",
          "type": "array"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "verifier_requirement_id": {
          "format": "uuid",
          "title": "Verifier Requirement Id",
          "type": "string"
        }
      },
      "required": [
        "criterion_id",
        "verifier_requirement_id",
        "outcome",
        "required",
        "reason"
      ],
      "title": "CriterionEvaluation",
      "type": "object"
    },
    "ErrorInfo": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Details",
          "type": "object"
        },
        "error_type": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Type"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ErrorInfo",
      "type": "object"
    },
    "FindingSeverity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "FindingSeverity",
      "type": "string"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "VerificationBundle": {
      "additionalProperties": false,
      "properties": {
        "bundle_id": {
          "format": "uuid",
          "title": "Bundle Id",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "criterion_results": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Criterion Results",
          "type": "array"
        },
        "errored_required_criteria": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Errored Required Criteria",
          "type": "array"
        },
        "failed_required_criteria": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Failed Required Criteria",
          "type": "array"
        },
        "optional_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Optional Score",
          "type": "number"
        },
        "required_passed": {
          "title": "Required Passed",
          "type": "boolean"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        },
        "unverifiable_required_criteria": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Unverifiable Required Criteria",
          "type": "array"
        },
        "verifier_results": {
          "items": {
            "$ref": "#/$defs/VerifierResult"
          },
          "title": "Verifier Results",
          "type": "array"
        }
      },
      "required": [
        "bundle_id",
        "task_run_id",
        "criterion_results",
        "verifier_results",
        "required_passed",
        "optional_score",
        "created_at"
      ],
      "title": "VerificationBundle",
      "type": "object"
    },
    "VerificationSubjectRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "subject_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subject Id"
        },
        "subject_type": {
          "minLength": 1,
          "title": "Subject Type",
          "type": "string"
        }
      },
      "required": [
        "subject_type"
      ],
      "title": "VerificationSubjectRef",
      "type": "object"
    },
    "VerifierFinding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "evidence_artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Evidence Artifacts",
          "type": "array"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/FindingSeverity"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "VerifierFinding",
      "type": "object"
    },
    "VerifierResult": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence_artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Evidence Artifacts",
          "type": "array"
        },
        "findings": {
          "default": [],
          "items": {
            "$ref": "#/$defs/VerifierFinding"
          },
          "title": "Findings",
          "type": "array"
        },
        "finished_at": {
          "format": "date-time",
          "title": "Finished At",
          "type": "string"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/VerifierStatus"
        },
        "subject": {
          "$ref": "#/$defs/VerificationSubjectRef"
        },
        "verifier_id": {
          "minLength": 1,
          "title": "Verifier Id",
          "type": "string"
        },
        "verifier_result_id": {
          "format": "uuid",
          "title": "Verifier Result Id",
          "type": "string"
        },
        "verifier_version": {
          "minLength": 1,
          "title": "Verifier Version",
          "type": "string"
        }
      },
      "required": [
        "verifier_result_id",
        "verifier_id",
        "verifier_version",
        "subject",
        "status",
        "started_at",
        "finished_at"
      ],
      "title": "VerifierResult",
      "type": "object"
    },
    "VerifierStatus": {
      "enum": [
        "passed",
        "failed",
        "partial",
        "unverifiable",
        "error"
      ],
      "title": "VerifierStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/benchmark-run.schema.json",
  "additionalProperties": false,
  "properties": {
    "aggregate_metrics": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Aggregate Metrics",
      "type": "object"
    },
    "benchmark_id": {
      "minLength": 1,
      "title": "Benchmark Id",
      "type": "string"
    },
    "benchmark_version": {
      "minLength": 1,
      "title": "Benchmark Version",
      "type": "string"
    },
    "case_results": {
      "default": [],
      "items": {
        "$ref": "#/$defs/BenchmarkCaseResult"
      },
      "title": "Case Results",
      "type": "array"
    },
    "configuration_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Configuration Hash",
      "type": "string"
    },
    "finished_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finished At"
    },
    "git_commit": {
      "minLength": 1,
      "title": "Git Commit",
      "type": "string"
    },
    "manifest_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Manifest Hash",
      "type": "string"
    },
    "provider_configuration_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Provider Configuration Hash",
      "type": "string"
    },
    "random_seed": {
      "title": "Random Seed",
      "type": "integer"
    },
    "report_artifact": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "sandbox_image_digest": {
      "minLength": 1,
      "title": "Sandbox Image Digest",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/BenchmarkRunStatus"
    },
    "tool_registry_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Tool Registry Hash",
      "type": "string"
    },
    "verifier_registry_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Verifier Registry Hash",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "benchmark_id",
    "benchmark_version",
    "manifest_hash",
    "git_commit",
    "configuration_hash",
    "provider_configuration_hash",
    "tool_registry_hash",
    "verifier_registry_hash",
    "sandbox_image_digest",
    "random_seed",
    "status",
    "started_at"
  ],
  "title": "BenchmarkRun",
  "type": "object"
}
