{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/unified-diff-artifact.schema.json",
  "additionalProperties": false,
  "properties": {
    "artifact": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "base_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "title": "Base Commit",
      "type": "string"
    },
    "diff_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Diff Hash",
      "type": "string"
    },
    "truncated": {
      "default": false,
      "title": "Truncated",
      "type": "boolean"
    }
  },
  "required": [
    "base_commit",
    "diff_hash",
    "artifact"
  ],
  "title": "UnifiedDiffArtifact",
  "type": "object"
}
