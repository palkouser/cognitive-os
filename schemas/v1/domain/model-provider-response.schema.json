{
  "$defs": {
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "ModelFinishReason": {
      "enum": [
        "completed",
        "tool_call",
        "length",
        "content_filter",
        "cancelled",
        "error",
        "unknown"
      ],
      "title": "ModelFinishReason",
      "type": "string"
    },
    "NormalizedToolCall": {
      "additionalProperties": false,
      "properties": {
        "arguments": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Arguments",
          "type": "object"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "tool_call_id": {
          "minLength": 1,
          "title": "Tool Call Id",
          "type": "string"
        }
      },
      "required": [
        "tool_call_id",
        "name",
        "arguments"
      ],
      "title": "NormalizedToolCall",
      "type": "object"
    },
    "TokenUsage": {
      "additionalProperties": false,
      "properties": {
        "cached_input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cached Input Tokens"
        },
        "input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "output_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "reasoning_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Tokens"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        }
      },
      "title": "TokenUsage",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/model-provider-response.schema.json",
  "additionalProperties": false,
  "properties": {
    "content": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content"
    },
    "finish_reason": {
      "$ref": "#/$defs/ModelFinishReason"
    },
    "latency_ms": {
      "minimum": 0,
      "title": "Latency Ms",
      "type": "number"
    },
    "model_call_id": {
      "format": "uuid",
      "title": "Model Call Id",
      "type": "string"
    },
    "provider_id": {
      "minLength": 1,
      "title": "Provider Id",
      "type": "string"
    },
    "provider_request_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Request Id"
    },
    "requested_model": {
      "minLength": 1,
      "title": "Requested Model",
      "type": "string"
    },
    "resolved_model": {
      "minLength": 1,
      "title": "Resolved Model",
      "type": "string"
    },
    "structured_output": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Structured Output"
    },
    "tool_calls": {
      "default": [],
      "items": {
        "$ref": "#/$defs/NormalizedToolCall"
      },
      "title": "Tool Calls",
      "type": "array"
    },
    "usage": {
      "anyOf": [
        {
          "$ref": "#/$defs/TokenUsage"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "model_call_id",
    "provider_id",
    "requested_model",
    "resolved_model",
    "finish_reason",
    "latency_ms"
  ],
  "title": "ModelProviderResponse",
  "type": "object"
}
