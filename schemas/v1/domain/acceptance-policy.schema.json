{
  "$defs": {
    "VerifierRequirement": {
      "additionalProperties": false,
      "properties": {
        "allowed_outcomes": {
          "default": [
            "passed"
          ],
          "items": {
            "$ref": "#/$defs/VerifierStatus"
          },
          "title": "Allowed Outcomes",
          "type": "array"
        },
        "criterion_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "minItems": 1,
          "title": "Criterion Ids",
          "type": "array"
        },
        "minimum_score": {
          "default": 1,
          "maximum": 1,
          "minimum": 0,
          "title": "Minimum Score",
          "type": "number"
        },
        "minimum_version": {
          "minLength": 1,
          "title": "Minimum Version",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "requirement_id": {
          "format": "uuid",
          "title": "Requirement Id",
          "type": "string"
        },
        "verifier_id": {
          "minLength": 1,
          "title": "Verifier Id",
          "type": "string"
        },
        "weight": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Weight",
          "type": "number"
        }
      },
      "required": [
        "requirement_id",
        "verifier_id",
        "minimum_version",
        "criterion_ids"
      ],
      "title": "VerifierRequirement",
      "type": "object"
    },
    "VerifierStatus": {
      "enum": [
        "passed",
        "failed",
        "partial",
        "unverifiable",
        "error"
      ],
      "title": "VerifierStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/acceptance-policy.schema.json",
  "additionalProperties": false,
  "properties": {
    "allow_partial": {
      "default": false,
      "title": "Allow Partial",
      "type": "boolean"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "maximum_unverifiable_required": {
      "default": 0,
      "minimum": 0,
      "title": "Maximum Unverifiable Required",
      "type": "integer"
    },
    "maximum_verifier_errors": {
      "default": 0,
      "minimum": 0,
      "title": "Maximum Verifier Errors",
      "type": "integer"
    },
    "minimum_optional_score": {
      "default": 0,
      "maximum": 1,
      "minimum": 0,
      "title": "Minimum Optional Score",
      "type": "number"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "policy_hash": {
      "default": "",
      "title": "Policy Hash",
      "type": "string"
    },
    "policy_id": {
      "format": "uuid",
      "title": "Policy Id",
      "type": "string"
    },
    "requirements": {
      "items": {
        "$ref": "#/$defs/VerifierRequirement"
      },
      "minItems": 1,
      "title": "Requirements",
      "type": "array"
    },
    "version": {
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "policy_id",
    "version",
    "name",
    "description",
    "requirements",
    "created_at"
  ],
  "title": "AcceptancePolicy",
  "type": "object"
}
