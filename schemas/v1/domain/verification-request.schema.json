{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "VerificationSubject": {
      "additionalProperties": false,
      "properties": {
        "artifact_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Artifact Refs",
          "type": "array"
        },
        "inline_value": {
          "$ref": "#/$defs/JsonValue",
          "default": null
        },
        "source_event_ids": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Source Event Ids",
          "type": "array"
        },
        "subject_type": {
          "$ref": "#/$defs/VerificationSubjectType"
        },
        "workspace_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Workspace Path"
        }
      },
      "required": [
        "subject_type"
      ],
      "title": "VerificationSubject",
      "type": "object"
    },
    "VerificationSubjectType": {
      "enum": [
        "structured_value",
        "artifact",
        "workspace",
        "execution_plan",
        "execution_step",
        "model_response",
        "tool_result",
        "mathematical_expression",
        "logical_problem",
        "physical_quantity",
        "semantic_snapshot"
      ],
      "title": "VerificationSubjectType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/verification-request.schema.json",
  "additionalProperties": false,
  "properties": {
    "causation_event_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Causation Event Id"
    },
    "configuration": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Configuration",
      "type": "object"
    },
    "correlation_id": {
      "format": "uuid",
      "title": "Correlation Id",
      "type": "string"
    },
    "criterion_id": {
      "format": "uuid",
      "title": "Criterion Id",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "step_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Step Id"
    },
    "subject": {
      "$ref": "#/$defs/VerificationSubject"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "verifier_id": {
      "minLength": 1,
      "title": "Verifier Id",
      "type": "string"
    },
    "verifier_version": {
      "minLength": 1,
      "title": "Verifier Version",
      "type": "string"
    }
  },
  "required": [
    "verification_id",
    "task_run_id",
    "criterion_id",
    "verifier_id",
    "verifier_version",
    "subject",
    "requested_at",
    "correlation_id"
  ],
  "title": "VerificationRequest",
  "type": "object"
}
