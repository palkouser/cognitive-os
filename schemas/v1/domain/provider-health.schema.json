{
  "$defs": {
    "ErrorInfo": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Details",
          "type": "object"
        },
        "error_type": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Type"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ErrorInfo",
      "type": "object"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "ProviderStatus": {
      "enum": [
        "available",
        "degraded",
        "unavailable",
        "misconfigured",
        "unauthenticated"
      ],
      "title": "ProviderStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/domain/provider-health.schema.json",
  "additionalProperties": false,
  "properties": {
    "checked_at": {
      "format": "date-time",
      "title": "Checked At",
      "type": "string"
    },
    "configured_model": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Configured Model"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorInfo"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "latency_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latency Ms"
    },
    "message": {
      "minLength": 1,
      "title": "Message",
      "type": "string"
    },
    "provider_id": {
      "minLength": 1,
      "title": "Provider Id",
      "type": "string"
    },
    "resolved_model": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resolved Model"
    },
    "status": {
      "$ref": "#/$defs/ProviderStatus"
    }
  },
  "required": [
    "provider_id",
    "status",
    "checked_at",
    "message"
  ],
  "title": "ProviderHealth",
  "type": "object"
}
