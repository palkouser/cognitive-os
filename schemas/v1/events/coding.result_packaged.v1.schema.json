{
  "$id": "https://cognitive-os.local/schemas/v1/events/coding.result_packaged.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "outcome_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Outcome Hash",
      "type": "string"
    },
    "packaged_at": {
      "format": "date-time",
      "title": "Packaged At",
      "type": "string"
    },
    "status": {
      "minLength": 1,
      "title": "Status",
      "type": "string"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    }
  },
  "required": [
    "task_run_id",
    "outcome_hash",
    "status",
    "packaged_at"
  ],
  "title": "CodingResultPackaged",
  "type": "object"
}
