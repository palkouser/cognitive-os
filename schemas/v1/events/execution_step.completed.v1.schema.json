{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/execution_step.completed.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "finished_at": {
      "format": "date-time",
      "title": "Finished At",
      "type": "string"
    },
    "output_artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Output Artifacts",
      "type": "array"
    },
    "step_id": {
      "format": "uuid",
      "title": "Step Id",
      "type": "string"
    }
  },
  "required": [
    "step_id",
    "finished_at"
  ],
  "title": "ExecutionStepCompleted",
  "type": "object"
}
