{
  "$defs": {
    "SkillExecutionStatus": {
      "enum": [
        "preparing",
        "running",
        "waiting",
        "accepted",
        "rejected",
        "unverifiable",
        "failed",
        "cancelled"
      ],
      "title": "SkillExecutionStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/skill.execution_completed.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "execution_id": {
      "format": "uuid",
      "title": "Execution Id",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "result_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Result Hash",
      "type": "string"
    },
    "revision": {
      "title": "Revision",
      "type": "integer"
    },
    "skill_id": {
      "format": "uuid",
      "title": "Skill Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/SkillExecutionStatus"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    }
  },
  "required": [
    "execution_id",
    "skill_id",
    "revision",
    "task_run_id",
    "status",
    "result_hash",
    "occurred_at"
  ],
  "title": "SkillExecutionCompleted",
  "type": "object"
}
