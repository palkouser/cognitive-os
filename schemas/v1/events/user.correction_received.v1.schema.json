{
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/ActorType"
        },
        "display_name": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ActorType": {
      "enum": [
        "user",
        "agent",
        "model",
        "tool",
        "verifier",
        "system"
      ],
      "title": "ActorType",
      "type": "string"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/user.correction_received.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "correction": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Correction",
      "type": "object"
    },
    "received_at": {
      "format": "date-time",
      "title": "Received At",
      "type": "string"
    },
    "received_from": {
      "$ref": "#/$defs/ActorRef"
    },
    "source": {
      "title": "Source",
      "type": "string"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    }
  },
  "required": [
    "task_run_id",
    "correction",
    "received_from",
    "received_at",
    "source"
  ],
  "title": "UserCorrectionReceived",
  "type": "object"
}
