{
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/ActorType"
        },
        "display_name": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ActorType": {
      "enum": [
        "user",
        "agent",
        "model",
        "tool",
        "verifier",
        "system"
      ],
      "title": "ActorType",
      "type": "string"
    },
    "PrivacyClass": {
      "enum": [
        "public",
        "internal",
        "sensitive",
        "secret"
      ],
      "title": "PrivacyClass",
      "type": "string"
    },
    "RiskLevel": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "RiskLevel",
      "type": "string"
    },
    "Task": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "normalized_request": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Normalized Request"
        },
        "priority": {
          "$ref": "#/$defs/TaskPriority",
          "default": "normal"
        },
        "privacy_class": {
          "$ref": "#/$defs/PrivacyClass",
          "default": "internal"
        },
        "raw_request": {
          "minLength": 1,
          "title": "Raw Request",
          "type": "string"
        },
        "requested_by": {
          "$ref": "#/$defs/ActorRef"
        },
        "risk_level": {
          "$ref": "#/$defs/RiskLevel",
          "default": "low"
        },
        "status": {
          "$ref": "#/$defs/TaskStatus",
          "default": "created"
        },
        "tags": {
          "default": [],
          "items": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "task_id": {
          "format": "uuid",
          "title": "Task Id",
          "type": "string"
        },
        "title": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "task_id",
        "title",
        "raw_request",
        "created_at",
        "updated_at",
        "requested_by"
      ],
      "title": "Task",
      "type": "object"
    },
    "TaskPriority": {
      "enum": [
        "low",
        "normal",
        "high",
        "critical"
      ],
      "title": "TaskPriority",
      "type": "string"
    },
    "TaskStatus": {
      "enum": [
        "created",
        "ready",
        "running",
        "waiting",
        "completed",
        "failed",
        "cancelled"
      ],
      "title": "TaskStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/task.updated.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "changed_fields": {
      "items": {
        "type": "string"
      },
      "title": "Changed Fields",
      "type": "array"
    },
    "current_snapshot": {
      "$ref": "#/$defs/Task"
    },
    "previous_status": {
      "$ref": "#/$defs/TaskStatus"
    },
    "task_id": {
      "format": "uuid",
      "title": "Task Id",
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "previous_status",
    "current_snapshot",
    "changed_fields"
  ],
  "title": "TaskUpdated",
  "type": "object"
}
