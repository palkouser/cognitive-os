{
  "$id": "https://cognitive-os.local/schemas/v1/events/memory.ingestion_rejected.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "ingestion_id": {
      "format": "uuid",
      "title": "Ingestion Id",
      "type": "string"
    },
    "reason_code": {
      "minLength": 1,
      "title": "Reason Code",
      "type": "string"
    },
    "rejected_at": {
      "format": "date-time",
      "title": "Rejected At",
      "type": "string"
    },
    "source_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Source Hash",
      "type": "string"
    }
  },
  "required": [
    "ingestion_id",
    "source_hash",
    "reason_code",
    "rejected_at"
  ],
  "title": "MemoryIngestionRejected",
  "type": "object"
}
