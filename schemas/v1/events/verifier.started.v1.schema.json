{
  "$defs": {
    "VerificationSubjectRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "subject_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subject Id"
        },
        "subject_type": {
          "minLength": 1,
          "title": "Subject Type",
          "type": "string"
        }
      },
      "required": [
        "subject_type"
      ],
      "title": "VerificationSubjectRef",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/verifier.started.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "configuration_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Configuration Hash"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "subject": {
      "$ref": "#/$defs/VerificationSubjectRef"
    },
    "verifier_id": {
      "title": "Verifier Id",
      "type": "string"
    },
    "verifier_result_id": {
      "format": "uuid",
      "title": "Verifier Result Id",
      "type": "string"
    },
    "verifier_version": {
      "default": "1",
      "title": "Verifier Version",
      "type": "string"
    }
  },
  "required": [
    "verifier_result_id",
    "verifier_id",
    "subject",
    "started_at"
  ],
  "title": "VerifierStarted",
  "type": "object"
}
