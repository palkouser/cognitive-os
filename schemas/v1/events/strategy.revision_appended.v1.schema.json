{
  "$defs": {
    "StrategyStatus": {
      "enum": [
        "draft",
        "staged",
        "verified",
        "deprecated",
        "superseded",
        "retracted"
      ],
      "title": "StrategyStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/strategy.revision_appended.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "previous_revision": {
      "title": "Previous Revision",
      "type": "integer"
    },
    "revision": {
      "title": "Revision",
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/StrategyStatus"
    },
    "strategy_id": {
      "format": "uuid",
      "title": "Strategy Id",
      "type": "string"
    }
  },
  "required": [
    "strategy_id",
    "revision",
    "status",
    "content_hash",
    "occurred_at",
    "previous_revision"
  ],
  "title": "StrategyRevisionAppended",
  "type": "object"
}
