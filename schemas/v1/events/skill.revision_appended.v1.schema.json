{
  "$defs": {
    "SkillStatus": {
      "enum": [
        "draft",
        "staged",
        "verified",
        "deprecated",
        "superseded",
        "retracted"
      ],
      "title": "SkillStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/skill.revision_appended.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "package_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Package Hash",
      "type": "string"
    },
    "previous_revision": {
      "title": "Previous Revision",
      "type": "integer"
    },
    "revision": {
      "title": "Revision",
      "type": "integer"
    },
    "skill_id": {
      "format": "uuid",
      "title": "Skill Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/SkillStatus"
    }
  },
  "required": [
    "skill_id",
    "revision",
    "status",
    "package_hash",
    "occurred_at",
    "previous_revision"
  ],
  "title": "SkillRevisionAppended",
  "type": "object"
}
