{
  "$defs": {
    "EvidenceValidationResult": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "format": "uuid",
          "title": "Evidence Id",
          "type": "string"
        },
        "reason_codes": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Reason Codes",
          "type": "array"
        },
        "valid": {
          "title": "Valid",
          "type": "boolean"
        },
        "validated_at": {
          "format": "date-time",
          "title": "Validated At",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "valid",
        "reason_codes",
        "validated_at"
      ],
      "title": "EvidenceValidationResult",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/events/semantic.evidence_reevaluated.v1.schema.json",
  "additionalProperties": false,
  "properties": {
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/EvidenceValidationResult"
      },
      "title": "Results",
      "type": "array"
    },
    "revision": {
      "title": "Revision",
      "type": "integer"
    },
    "validation_id": {
      "format": "uuid",
      "title": "Validation Id",
      "type": "string"
    }
  },
  "required": [
    "validation_id",
    "claim_id",
    "revision",
    "results"
  ],
  "title": "SemanticEvidenceReevaluated",
  "type": "object"
}
