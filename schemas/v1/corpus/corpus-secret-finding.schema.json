{
  "$id": "https://cognitive-os.local/schemas/v1/corpus/corpus-secret-finding.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "finding_type": {
      "minLength": 1,
      "title": "Finding Type",
      "type": "string"
    },
    "fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Fingerprint",
      "type": "string"
    },
    "line_number": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Line Number"
    },
    "relative_path": {
      "minLength": 1,
      "title": "Relative Path",
      "type": "string"
    }
  },
  "required": [
    "finding_type",
    "relative_path",
    "fingerprint"
  ],
  "title": "CorpusSecretFinding",
  "type": "object"
}
