{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "CorpusDestinationType": {
      "enum": [
        "governed_memory_candidate",
        "semantic_observation_candidate",
        "skill_candidate",
        "strategy_candidate",
        "routing_observation",
        "weakness_signal",
        "benchmark_case",
        "replay_fixture",
        "negative_example",
        "training_corpus",
        "reference_corpus",
        "quarantine",
        "reject"
      ],
      "title": "CorpusDestinationType",
      "type": "string"
    },
    "DestinationPackageReference": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "$ref": "#/$defs/ArtifactRef"
        },
        "authority_claims": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Authority Claims",
          "type": "array"
        },
        "checksums": {
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Checksums",
          "type": "array"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "corpus_item_id": {
          "format": "uuid",
          "title": "Corpus Item Id",
          "type": "string"
        },
        "destination": {
          "$ref": "#/$defs/CorpusDestinationType"
        },
        "item_revision": {
          "minimum": 1,
          "title": "Item Revision",
          "type": "integer"
        },
        "package_id": {
          "format": "uuid",
          "title": "Package Id",
          "type": "string"
        },
        "schema_version": {
          "minLength": 1,
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "package_id",
        "corpus_item_id",
        "item_revision",
        "destination",
        "schema_version",
        "artifact",
        "checksums"
      ],
      "title": "DestinationPackageReference",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/corpus/corpus-routing-receipt.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "package": {
      "$ref": "#/$defs/DestinationPackageReference"
    },
    "promoted": {
      "default": false,
      "title": "Promoted",
      "type": "boolean"
    },
    "receipt_id": {
      "format": "uuid",
      "title": "Receipt Id",
      "type": "string"
    },
    "route_decision_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Route Decision Hash",
      "type": "string"
    }
  },
  "required": [
    "receipt_id",
    "route_decision_hash",
    "package",
    "created_at"
  ],
  "title": "CorpusRoutingReceipt",
  "type": "object"
}
