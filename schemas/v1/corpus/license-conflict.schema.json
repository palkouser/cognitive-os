{
  "$id": "https://cognitive-os.local/schemas/v1/corpus/license-conflict.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "identifiers": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 2,
      "title": "Identifiers",
      "type": "array"
    }
  },
  "required": [
    "identifiers",
    "evidence_refs"
  ],
  "title": "LicenseConflict",
  "type": "object"
}
