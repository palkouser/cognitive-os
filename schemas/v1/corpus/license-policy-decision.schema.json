{
  "$defs": {
    "CorpusDestinationType": {
      "enum": [
        "governed_memory_candidate",
        "semantic_observation_candidate",
        "skill_candidate",
        "strategy_candidate",
        "routing_observation",
        "weakness_signal",
        "benchmark_case",
        "replay_fixture",
        "negative_example",
        "training_corpus",
        "reference_corpus",
        "quarantine",
        "reject"
      ],
      "title": "CorpusDestinationType",
      "type": "string"
    },
    "LicensePolicyOutcome": {
      "enum": [
        "allowed",
        "allowed_internal_only",
        "requires_review",
        "quarantined",
        "rejected"
      ],
      "title": "LicensePolicyOutcome",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/corpus/license-policy-decision.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "corpus_item_id": {
      "format": "uuid",
      "title": "Corpus Item Id",
      "type": "string"
    },
    "destination": {
      "$ref": "#/$defs/CorpusDestinationType"
    },
    "evidence_refs": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "outcome": {
      "$ref": "#/$defs/LicensePolicyOutcome"
    },
    "policy_id": {
      "minLength": 1,
      "title": "Policy Id",
      "type": "string"
    },
    "policy_version": {
      "minimum": 1,
      "title": "Policy Version",
      "type": "integer"
    },
    "reason_codes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Reason Codes",
      "type": "array"
    }
  },
  "required": [
    "corpus_item_id",
    "destination",
    "outcome",
    "policy_id",
    "policy_version",
    "reason_codes",
    "evidence_refs"
  ],
  "title": "LicensePolicyDecision",
  "type": "object"
}
