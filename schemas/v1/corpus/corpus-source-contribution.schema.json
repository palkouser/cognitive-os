{
  "$id": "https://cognitive-os.local/schemas/v1/corpus/corpus-source-contribution.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "contribution": {
      "minLength": 1,
      "title": "Contribution",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "source_manifest_id": {
      "format": "uuid",
      "title": "Source Manifest Id",
      "type": "string"
    }
  },
  "required": [
    "source_manifest_id",
    "contribution",
    "evidence_refs"
  ],
  "title": "CorpusSourceContribution",
  "type": "object"
}
