{
  "$defs": {
    "CorpusDestinationType": {
      "enum": [
        "governed_memory_candidate",
        "semantic_observation_candidate",
        "skill_candidate",
        "strategy_candidate",
        "routing_observation",
        "weakness_signal",
        "benchmark_case",
        "replay_fixture",
        "negative_example",
        "training_corpus",
        "reference_corpus",
        "quarantine",
        "reject"
      ],
      "title": "CorpusDestinationType",
      "type": "string"
    },
    "CorpusSensitivityStatus": {
      "enum": [
        "allowed",
        "requires_review",
        "quarantined",
        "rejected"
      ],
      "title": "CorpusSensitivityStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/corpus/sensitivity-policy-decision.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "corpus_item_id": {
      "format": "uuid",
      "title": "Corpus Item Id",
      "type": "string"
    },
    "destination": {
      "$ref": "#/$defs/CorpusDestinationType"
    },
    "reason_codes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Reason Codes",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/CorpusSensitivityStatus"
    }
  },
  "required": [
    "corpus_item_id",
    "destination",
    "status",
    "reason_codes"
  ],
  "title": "SensitivityPolicyDecision",
  "type": "object"
}
