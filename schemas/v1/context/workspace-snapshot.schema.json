{
  "$id": "https://cognitive-os.local/schemas/v1/context/workspace-snapshot.schema.json",
  "additionalProperties": false,
  "properties": {
    "diff_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Diff Hash",
      "type": "string"
    },
    "workspace_id": {
      "format": "uuid",
      "title": "Workspace Id",
      "type": "string"
    },
    "workspace_revision": {
      "minimum": 0,
      "title": "Workspace Revision",
      "type": "integer"
    }
  },
  "required": [
    "workspace_id",
    "workspace_revision",
    "diff_hash"
  ],
  "title": "WorkspaceSnapshot",
  "type": "object"
}
