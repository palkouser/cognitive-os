{
  "$defs": {
    "ContextSourceReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "source_identity": {
          "minLength": 1,
          "title": "Source Identity",
          "type": "string"
        },
        "source_revision": {
          "minLength": 1,
          "title": "Source Revision",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/ContextSourceType"
        },
        "start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        }
      },
      "required": [
        "source_type",
        "source_identity",
        "source_revision",
        "content_hash"
      ],
      "title": "ContextSourceReference",
      "type": "object"
    },
    "ContextSourceType": {
      "enum": [
        "task_state",
        "execution_plan",
        "event",
        "provider_result",
        "tool_result",
        "artifact",
        "memory",
        "semantic_claim",
        "semantic_graph",
        "wiki",
        "repository_index",
        "workspace",
        "user_correction",
        "procedural_skill",
        "strategy"
      ],
      "title": "ContextSourceType",
      "type": "string"
    },
    "ContextTrustClass": {
      "enum": [
        "system",
        "verified",
        "user_provided",
        "unverified",
        "external",
        "disputed"
      ],
      "title": "ContextTrustClass",
      "type": "string"
    },
    "ContextWarning": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "source_references": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ContextSourceReference"
          },
          "title": "Source References",
          "type": "array"
        },
        "warning_type": {
          "$ref": "#/$defs/ContextWarningType"
        }
      },
      "required": [
        "warning_type",
        "code",
        "message"
      ],
      "title": "ContextWarning",
      "type": "object"
    },
    "ContextWarningType": {
      "enum": [
        "suspicious_instruction",
        "contradiction",
        "optional_source_unavailable",
        "quota_unmet",
        "content_truncated",
        "stale_optional_source"
      ],
      "title": "ContextWarningType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/context/context-section.schema.json",
  "additionalProperties": false,
  "properties": {
    "candidate_references": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "minItems": 1,
      "title": "Candidate References",
      "type": "array"
    },
    "content": {
      "title": "Content",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "section_id": {
      "format": "uuid",
      "title": "Section Id",
      "type": "string"
    },
    "section_type": {
      "minLength": 1,
      "title": "Section Type",
      "type": "string"
    },
    "source_references": {
      "items": {
        "$ref": "#/$defs/ContextSourceReference"
      },
      "minItems": 1,
      "title": "Source References",
      "type": "array"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "token_estimate": {
      "minimum": 0,
      "title": "Token Estimate",
      "type": "integer"
    },
    "trust_class": {
      "$ref": "#/$defs/ContextTrustClass"
    },
    "warnings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ContextWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "section_id",
    "section_type",
    "title",
    "trust_class",
    "content",
    "source_references",
    "candidate_references",
    "token_estimate",
    "content_hash"
  ],
  "title": "ContextSection",
  "type": "object"
}
