{
  "$defs": {
    "ContextSourceType": {
      "enum": [
        "task_state",
        "execution_plan",
        "event",
        "provider_result",
        "tool_result",
        "artifact",
        "memory",
        "semantic_claim",
        "semantic_graph",
        "wiki",
        "repository_index",
        "workspace",
        "user_correction",
        "procedural_skill",
        "strategy"
      ],
      "title": "ContextSourceType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/context/context-source-reference.schema.json",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Artifact Id"
    },
    "content_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "end": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "End"
    },
    "source_identity": {
      "minLength": 1,
      "title": "Source Identity",
      "type": "string"
    },
    "source_revision": {
      "minLength": 1,
      "title": "Source Revision",
      "type": "string"
    },
    "source_type": {
      "$ref": "#/$defs/ContextSourceType"
    },
    "start": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Start"
    }
  },
  "required": [
    "source_type",
    "source_identity",
    "source_revision",
    "content_hash"
  ],
  "title": "ContextSourceReference",
  "type": "object"
}
