{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ArtifactSnapshot": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "content_hash"
      ],
      "title": "ArtifactSnapshot",
      "type": "object"
    },
    "ContextExclusion": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "detail_code": {
          "minLength": 1,
          "title": "Detail Code",
          "type": "string"
        },
        "reason": {
          "$ref": "#/$defs/ContextExclusionReason"
        },
        "source_identity_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Identity Hash",
          "type": "string"
        }
      },
      "required": [
        "source_identity_hash",
        "reason",
        "detail_code"
      ],
      "title": "ContextExclusion",
      "type": "object"
    },
    "ContextExclusionReason": {
      "enum": [
        "scope_mismatch",
        "sensitivity_exceeded",
        "status_not_allowed",
        "duplicate",
        "lower_rank",
        "source_limit",
        "token_budget",
        "secret_detected",
        "stale_source",
        "invalid_provenance",
        "unavailable_retriever",
        "unsafe_content"
      ],
      "title": "ContextExclusionReason",
      "type": "string"
    },
    "ContextSection": {
      "additionalProperties": false,
      "properties": {
        "candidate_references": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "minItems": 1,
          "title": "Candidate References",
          "type": "array"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "section_id": {
          "format": "uuid",
          "title": "Section Id",
          "type": "string"
        },
        "section_type": {
          "minLength": 1,
          "title": "Section Type",
          "type": "string"
        },
        "source_references": {
          "items": {
            "$ref": "#/$defs/ContextSourceReference"
          },
          "minItems": 1,
          "title": "Source References",
          "type": "array"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "token_estimate": {
          "minimum": 0,
          "title": "Token Estimate",
          "type": "integer"
        },
        "trust_class": {
          "$ref": "#/$defs/ContextTrustClass"
        },
        "warnings": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ContextWarning"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "section_id",
        "section_type",
        "title",
        "trust_class",
        "content",
        "source_references",
        "candidate_references",
        "token_estimate",
        "content_hash"
      ],
      "title": "ContextSection",
      "type": "object"
    },
    "ContextSourceReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "source_identity": {
          "minLength": 1,
          "title": "Source Identity",
          "type": "string"
        },
        "source_revision": {
          "minLength": 1,
          "title": "Source Revision",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/ContextSourceType"
        },
        "start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        }
      },
      "required": [
        "source_type",
        "source_identity",
        "source_revision",
        "content_hash"
      ],
      "title": "ContextSourceReference",
      "type": "object"
    },
    "ContextSourceSnapshot": {
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactSnapshot"
          },
          "title": "Artifacts",
          "type": "array"
        },
        "captured_at": {
          "format": "date-time",
          "title": "Captured At",
          "type": "string"
        },
        "event_streams": {
          "default": [],
          "items": {
            "$ref": "#/$defs/EventStreamSnapshot"
          },
          "title": "Event Streams",
          "type": "array"
        },
        "memory_revisions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/MemoryRevisionSnapshot"
          },
          "title": "Memory Revisions",
          "type": "array"
        },
        "repository": {
          "anyOf": [
            {
              "$ref": "#/$defs/RepositorySnapshot"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "semantic_revisions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SemanticRevisionSnapshot"
          },
          "title": "Semantic Revisions",
          "type": "array"
        },
        "snapshot_hash": {
          "default": "",
          "title": "Snapshot Hash",
          "type": "string"
        },
        "strategy_revisions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/StrategyRevisionSnapshot"
          },
          "title": "Strategy Revisions",
          "type": "array"
        },
        "workspace": {
          "anyOf": [
            {
              "$ref": "#/$defs/WorkspaceSnapshot"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "captured_at"
      ],
      "title": "ContextSourceSnapshot",
      "type": "object"
    },
    "ContextSourceType": {
      "enum": [
        "task_state",
        "execution_plan",
        "event",
        "provider_result",
        "tool_result",
        "artifact",
        "memory",
        "semantic_claim",
        "semantic_graph",
        "wiki",
        "repository_index",
        "workspace",
        "user_correction",
        "procedural_skill",
        "strategy"
      ],
      "title": "ContextSourceType",
      "type": "string"
    },
    "ContextTrustClass": {
      "enum": [
        "system",
        "verified",
        "user_provided",
        "unverified",
        "external",
        "disputed"
      ],
      "title": "ContextTrustClass",
      "type": "string"
    },
    "ContextWarning": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "source_references": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ContextSourceReference"
          },
          "title": "Source References",
          "type": "array"
        },
        "warning_type": {
          "$ref": "#/$defs/ContextWarningType"
        }
      },
      "required": [
        "warning_type",
        "code",
        "message"
      ],
      "title": "ContextWarning",
      "type": "object"
    },
    "ContextWarningType": {
      "enum": [
        "suspicious_instruction",
        "contradiction",
        "optional_source_unavailable",
        "quota_unmet",
        "content_truncated",
        "stale_optional_source"
      ],
      "title": "ContextWarningType",
      "type": "string"
    },
    "EventStreamSnapshot": {
      "additionalProperties": false,
      "properties": {
        "stream_id": {
          "format": "uuid",
          "title": "Stream Id",
          "type": "string"
        },
        "upper_version": {
          "minimum": 0,
          "title": "Upper Version",
          "type": "integer"
        }
      },
      "required": [
        "stream_id",
        "upper_version"
      ],
      "title": "EventStreamSnapshot",
      "type": "object"
    },
    "MemoryRevisionSnapshot": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "memory_id": {
          "format": "uuid",
          "title": "Memory Id",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        }
      },
      "required": [
        "memory_id",
        "revision",
        "content_hash"
      ],
      "title": "MemoryRevisionSnapshot",
      "type": "object"
    },
    "MemorySensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "MemorySensitivity",
      "type": "string"
    },
    "ProviderContextProfile": {
      "additionalProperties": false,
      "properties": {
        "estimator": {
          "$ref": "#/$defs/TokenEstimatorProfile"
        },
        "maximum_context_tokens": {
          "exclusiveMinimum": 0,
          "maximum": 1000000,
          "title": "Maximum Context Tokens",
          "type": "integer"
        },
        "maximum_output_tokens": {
          "exclusiveMinimum": 0,
          "maximum": 1000000,
          "title": "Maximum Output Tokens",
          "type": "integer"
        },
        "profile_id": {
          "minLength": 1,
          "title": "Profile Id",
          "type": "string"
        },
        "safety_margin_tokens": {
          "minimum": 0,
          "title": "Safety Margin Tokens",
          "type": "integer"
        },
        "section_policy_version": {
          "default": "1",
          "minLength": 1,
          "title": "Section Policy Version",
          "type": "string"
        },
        "sensitivity_ceiling": {
          "$ref": "#/$defs/MemorySensitivity"
        }
      },
      "required": [
        "profile_id",
        "maximum_context_tokens",
        "maximum_output_tokens",
        "safety_margin_tokens",
        "estimator",
        "sensitivity_ceiling"
      ],
      "title": "ProviderContextProfile",
      "type": "object"
    },
    "RankingProfileReference": {
      "additionalProperties": false,
      "properties": {
        "profile_hash": {
          "default": "",
          "title": "Profile Hash",
          "type": "string"
        },
        "profile_id": {
          "minLength": 1,
          "title": "Profile Id",
          "type": "string"
        },
        "rrf_k": {
          "minimum": 1,
          "title": "Rrf K",
          "type": "integer"
        },
        "score_precision": {
          "maximum": 18,
          "minimum": 1,
          "title": "Score Precision",
          "type": "integer"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "weights": {
          "additionalProperties": {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "type": "string"
          },
          "title": "Weights",
          "type": "object"
        }
      },
      "required": [
        "profile_id",
        "version",
        "weights",
        "rrf_k",
        "score_precision"
      ],
      "title": "RankingProfileReference",
      "type": "object"
    },
    "RepositorySnapshot": {
      "additionalProperties": false,
      "properties": {
        "commit_hash": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Commit Hash",
          "type": "string"
        },
        "index_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Index Hash",
          "type": "string"
        },
        "repository_identity": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Repository Identity",
          "type": "string"
        }
      },
      "required": [
        "repository_identity",
        "commit_hash",
        "index_hash"
      ],
      "title": "RepositorySnapshot",
      "type": "object"
    },
    "SemanticRevisionSnapshot": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "format": "uuid",
          "title": "Claim Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        }
      },
      "required": [
        "claim_id",
        "revision",
        "content_hash"
      ],
      "title": "SemanticRevisionSnapshot",
      "type": "object"
    },
    "StrategyRevisionSnapshot": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        },
        "strategy_id": {
          "format": "uuid",
          "title": "Strategy Id",
          "type": "string"
        }
      },
      "required": [
        "strategy_id",
        "revision",
        "content_hash"
      ],
      "title": "StrategyRevisionSnapshot",
      "type": "object"
    },
    "TokenEstimatorProfile": {
      "additionalProperties": false,
      "properties": {
        "bytes_per_token": {
          "default": 3,
          "maximum": 16,
          "minimum": 1,
          "title": "Bytes Per Token",
          "type": "integer"
        },
        "estimator_id": {
          "minLength": 1,
          "title": "Estimator Id",
          "type": "string"
        },
        "estimator_type": {
          "$ref": "#/$defs/TokenEstimatorType"
        },
        "per_message_overhead": {
          "default": 4,
          "maximum": 1000,
          "minimum": 0,
          "title": "Per Message Overhead",
          "type": "integer"
        },
        "profile_hash": {
          "default": "",
          "title": "Profile Hash",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "estimator_type",
        "estimator_id",
        "version"
      ],
      "title": "TokenEstimatorProfile",
      "type": "object"
    },
    "TokenEstimatorType": {
      "enum": [
        "conservative_utf8",
        "provider"
      ],
      "title": "TokenEstimatorType",
      "type": "string"
    },
    "WorkspaceSnapshot": {
      "additionalProperties": false,
      "properties": {
        "diff_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Diff Hash",
          "type": "string"
        },
        "workspace_id": {
          "format": "uuid",
          "title": "Workspace Id",
          "type": "string"
        },
        "workspace_revision": {
          "minimum": 0,
          "title": "Workspace Revision",
          "type": "integer"
        }
      },
      "required": [
        "workspace_id",
        "workspace_revision",
        "diff_hash"
      ],
      "title": "WorkspaceSnapshot",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/context/context-bundle-revision.schema.json",
  "additionalProperties": false,
  "properties": {
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "context_bundle_id": {
      "format": "uuid",
      "title": "Context Bundle Id",
      "type": "string"
    },
    "context_request_id": {
      "format": "uuid",
      "title": "Context Request Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "excluded_candidates": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ContextExclusion"
      },
      "title": "Excluded Candidates",
      "type": "array"
    },
    "previous_revision": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Revision"
    },
    "provider_profile": {
      "$ref": "#/$defs/ProviderContextProfile"
    },
    "ranking_profile": {
      "$ref": "#/$defs/RankingProfileReference"
    },
    "rendered_context_reference": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "retrieval_trace_reference": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/ContextSection"
      },
      "title": "Sections",
      "type": "array"
    },
    "source_snapshot": {
      "$ref": "#/$defs/ContextSourceSnapshot"
    },
    "token_estimator_profile": {
      "$ref": "#/$defs/TokenEstimatorProfile"
    },
    "total_token_estimate": {
      "minimum": 0,
      "title": "Total Token Estimate",
      "type": "integer"
    },
    "warnings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ContextWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "context_bundle_id",
    "revision",
    "context_request_id",
    "sections",
    "total_token_estimate",
    "provider_profile",
    "source_snapshot",
    "ranking_profile",
    "token_estimator_profile",
    "created_at"
  ],
  "title": "ContextBundleRevision",
  "type": "object"
}
