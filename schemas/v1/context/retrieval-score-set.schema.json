{
  "$defs": {
    "RetrievalMode": {
      "enum": [
        "metadata",
        "lexical",
        "exact_vector",
        "graph",
        "recent",
        "source_lookup",
        "code"
      ],
      "title": "RetrievalMode",
      "type": "string"
    },
    "RetrieverRank": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/RetrievalMode"
        },
        "rank": {
          "minimum": 1,
          "title": "Rank",
          "type": "integer"
        },
        "raw_score": {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Raw Score",
          "type": "string"
        },
        "retriever_id": {
          "minLength": 1,
          "title": "Retriever Id",
          "type": "string"
        },
        "weight": {
          "default": "1",
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Weight",
          "type": "string"
        }
      },
      "required": [
        "retriever_id",
        "mode",
        "rank",
        "raw_score"
      ],
      "title": "RetrieverRank",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/context/retrieval-score-set.schema.json",
  "additionalProperties": false,
  "properties": {
    "ranks": {
      "items": {
        "$ref": "#/$defs/RetrieverRank"
      },
      "minItems": 1,
      "title": "Ranks",
      "type": "array"
    }
  },
  "required": [
    "ranks"
  ],
  "title": "RetrievalScoreSet",
  "type": "object"
}
