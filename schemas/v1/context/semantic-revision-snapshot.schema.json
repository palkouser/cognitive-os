{
  "$id": "https://cognitive-os.local/schemas/v1/context/semantic-revision-snapshot.schema.json",
  "additionalProperties": false,
  "properties": {
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    }
  },
  "required": [
    "claim_id",
    "revision",
    "content_hash"
  ],
  "title": "SemanticRevisionSnapshot",
  "type": "object"
}
