{
  "$defs": {
    "ClaimRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "format": "uuid",
          "title": "Claim Id",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        }
      },
      "required": [
        "claim_id",
        "revision"
      ],
      "title": "ClaimRevisionReference",
      "type": "object"
    },
    "WikiClaimReference": {
      "additionalProperties": false,
      "properties": {
        "claim": {
          "$ref": "#/$defs/ClaimRevisionReference"
        },
        "display_order": {
          "minimum": 0,
          "title": "Display Order",
          "type": "integer"
        },
        "section": {
          "$ref": "#/$defs/WikiSectionType"
        }
      },
      "required": [
        "claim",
        "section",
        "display_order"
      ],
      "title": "WikiClaimReference",
      "type": "object"
    },
    "WikiSectionType": {
      "enum": [
        "current_supported",
        "disputed",
        "open_contradictions",
        "superseded_history",
        "evidence_index",
        "revision_metadata"
      ],
      "title": "WikiSectionType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/wiki-page-revision.schema.json",
  "additionalProperties": false,
  "properties": {
    "claim_refs": {
      "items": {
        "$ref": "#/$defs/WikiClaimReference"
      },
      "title": "Claim Refs",
      "type": "array"
    },
    "content_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "known_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Known At"
    },
    "markdown": {
      "maxLength": 262144,
      "title": "Markdown",
      "type": "string"
    },
    "page_id": {
      "format": "uuid",
      "title": "Page Id",
      "type": "string"
    },
    "previous_revision": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Revision"
    },
    "rendered_at": {
      "format": "date-time",
      "title": "Rendered At",
      "type": "string"
    },
    "renderer_version": {
      "const": "3",
      "default": "3",
      "title": "Renderer Version",
      "type": "string"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "snapshot_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Snapshot Hash",
      "type": "string"
    },
    "valid_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Valid At"
    }
  },
  "required": [
    "page_id",
    "revision",
    "markdown",
    "claim_refs",
    "rendered_at",
    "content_hash",
    "snapshot_hash"
  ],
  "title": "WikiPageRevision",
  "type": "object"
}
