{
  "$defs": {
    "ClaimRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "format": "uuid",
          "title": "Claim Id",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        }
      },
      "required": [
        "claim_id",
        "revision"
      ],
      "title": "ClaimRevisionReference",
      "type": "object"
    },
    "ContradictionSeverity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "ContradictionSeverity",
      "type": "string"
    },
    "ContradictionStatus": {
      "enum": [
        "candidate",
        "open",
        "resolved",
        "dismissed"
      ],
      "title": "ContradictionStatus",
      "type": "string"
    },
    "SemanticActor": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/SemanticActorType"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "SemanticActor",
      "type": "object"
    },
    "SemanticActorType": {
      "enum": [
        "user",
        "operator",
        "controller",
        "semantic_service",
        "approved_internal_service",
        "provider"
      ],
      "title": "SemanticActorType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/contradiction-revision.schema.json",
  "additionalProperties": false,
  "properties": {
    "claims": {
      "items": {
        "$ref": "#/$defs/ClaimRevisionReference"
      },
      "maxItems": 32,
      "minItems": 2,
      "title": "Claims",
      "type": "array"
    },
    "content_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "contradiction_id": {
      "format": "uuid",
      "title": "Contradiction Id",
      "type": "string"
    },
    "evidence_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Evidence Ids",
      "type": "array"
    },
    "previous_revision": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Revision"
    },
    "reason": {
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "recorded_at": {
      "format": "date-time",
      "title": "Recorded At",
      "type": "string"
    },
    "resolver": {
      "anyOf": [
        {
          "$ref": "#/$defs/SemanticActor"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "severity": {
      "$ref": "#/$defs/ContradictionSeverity"
    },
    "status": {
      "$ref": "#/$defs/ContradictionStatus"
    }
  },
  "required": [
    "contradiction_id",
    "revision",
    "status",
    "severity",
    "claims",
    "evidence_ids",
    "reason",
    "recorded_at",
    "content_hash"
  ],
  "title": "ContradictionRevision",
  "type": "object"
}
