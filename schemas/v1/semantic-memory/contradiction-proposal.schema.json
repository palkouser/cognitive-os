{
  "$defs": {
    "ContradictionSeverity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "ContradictionSeverity",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/contradiction-proposal.schema.json",
  "additionalProperties": false,
  "properties": {
    "claim_proposal_ids": {
      "maxItems": 2,
      "minItems": 2,
      "prefixItems": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "format": "uuid",
          "type": "string"
        }
      ],
      "title": "Claim Proposal Ids",
      "type": "array"
    },
    "proposal_id": {
      "format": "uuid",
      "title": "Proposal Id",
      "type": "string"
    },
    "provider_confidence": {
      "anyOf": [
        {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Confidence"
    },
    "rule_id": {
      "minLength": 1,
      "title": "Rule Id",
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/ContradictionSeverity"
    }
  },
  "required": [
    "proposal_id",
    "claim_proposal_ids",
    "rule_id",
    "severity"
  ],
  "title": "ContradictionProposal",
  "type": "object"
}
