{
  "$defs": {
    "MemoryScope": {
      "additionalProperties": false,
      "properties": {
        "scope_id": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Scope Id",
          "type": "string"
        },
        "scope_type": {
          "$ref": "#/$defs/MemoryScopeType"
        }
      },
      "required": [
        "scope_type",
        "scope_id"
      ],
      "title": "MemoryScope",
      "type": "object"
    },
    "MemoryScopeType": {
      "enum": [
        "global",
        "project",
        "repository",
        "task",
        "session",
        "domain"
      ],
      "title": "MemoryScopeType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/claim-identity.schema.json",
  "additionalProperties": false,
  "properties": {
    "canonical_subject_key": {
      "maxLength": 1024,
      "minLength": 1,
      "title": "Canonical Subject Key",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "predicate_id": {
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$",
      "title": "Predicate Id",
      "type": "string"
    },
    "scope": {
      "$ref": "#/$defs/MemoryScope"
    }
  },
  "required": [
    "claim_id",
    "scope",
    "canonical_subject_key",
    "predicate_id"
  ],
  "title": "ClaimIdentity",
  "type": "object"
}
