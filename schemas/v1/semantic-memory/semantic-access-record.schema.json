{
  "$defs": {
    "MemoryScope": {
      "additionalProperties": false,
      "properties": {
        "scope_id": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Scope Id",
          "type": "string"
        },
        "scope_type": {
          "$ref": "#/$defs/MemoryScopeType"
        }
      },
      "required": [
        "scope_type",
        "scope_id"
      ],
      "title": "MemoryScope",
      "type": "object"
    },
    "MemoryScopeType": {
      "enum": [
        "global",
        "project",
        "repository",
        "task",
        "session",
        "domain"
      ],
      "title": "MemoryScopeType",
      "type": "string"
    },
    "MemorySensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "MemorySensitivity",
      "type": "string"
    },
    "TemporalQueryMode": {
      "enum": [
        "current",
        "valid_at",
        "known_at",
        "bitemporal"
      ],
      "title": "TemporalQueryMode",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/semantic-access-record.schema.json",
  "additionalProperties": false,
  "properties": {
    "access_id": {
      "format": "uuid",
      "title": "Access Id",
      "type": "string"
    },
    "accessed_at": {
      "format": "date-time",
      "title": "Accessed At",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "claim_revision": {
      "minimum": 1,
      "title": "Claim Revision",
      "type": "integer"
    },
    "known_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Known At"
    },
    "query_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Query Hash",
      "type": "string"
    },
    "query_id": {
      "format": "uuid",
      "title": "Query Id",
      "type": "string"
    },
    "query_mode": {
      "$ref": "#/$defs/TemporalQueryMode"
    },
    "rank": {
      "minimum": 1,
      "title": "Rank",
      "type": "integer"
    },
    "scope": {
      "$ref": "#/$defs/MemoryScope"
    },
    "sensitivity": {
      "$ref": "#/$defs/MemorySensitivity"
    },
    "task_run_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Run Id"
    },
    "used_in_wiki": {
      "default": false,
      "title": "Used In Wiki",
      "type": "boolean"
    },
    "valid_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Valid At"
    }
  },
  "required": [
    "access_id",
    "query_id",
    "claim_id",
    "claim_revision",
    "query_mode",
    "rank",
    "scope",
    "sensitivity",
    "query_hash",
    "accessed_at"
  ],
  "title": "SemanticAccessRecord",
  "type": "object"
}
