{
  "$defs": {
    "ClaimRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "format": "uuid",
          "title": "Claim Id",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        }
      },
      "required": [
        "claim_id",
        "revision"
      ],
      "title": "ClaimRevisionReference",
      "type": "object"
    },
    "ClaimTemporalInterval": {
      "additionalProperties": false,
      "properties": {
        "valid_from": {
          "format": "date-time",
          "title": "Valid From",
          "type": "string"
        },
        "valid_to": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid To"
        }
      },
      "required": [
        "valid_from"
      ],
      "title": "ClaimTemporalInterval",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/contradiction-candidate.schema.json",
  "additionalProperties": false,
  "properties": {
    "claims": {
      "maxItems": 2,
      "minItems": 2,
      "prefixItems": [
        {
          "$ref": "#/$defs/ClaimRevisionReference"
        },
        {
          "$ref": "#/$defs/ClaimRevisionReference"
        }
      ],
      "title": "Claims",
      "type": "array"
    },
    "deterministic": {
      "title": "Deterministic",
      "type": "boolean"
    },
    "overlap": {
      "$ref": "#/$defs/ClaimTemporalInterval"
    },
    "rule_id": {
      "minLength": 1,
      "title": "Rule Id",
      "type": "string"
    }
  },
  "required": [
    "claims",
    "overlap",
    "rule_id",
    "deterministic"
  ],
  "title": "ContradictionCandidate",
  "type": "object"
}
