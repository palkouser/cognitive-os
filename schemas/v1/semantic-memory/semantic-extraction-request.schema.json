{
  "$defs": {
    "ExtractionBudget": {
      "additionalProperties": false,
      "properties": {
        "maximum_claims": {
          "maximum": 100,
          "minimum": 1,
          "title": "Maximum Claims",
          "type": "integer"
        },
        "maximum_evidence_links": {
          "maximum": 3200,
          "minimum": 1,
          "title": "Maximum Evidence Links",
          "type": "integer"
        },
        "maximum_observations": {
          "maximum": 100,
          "minimum": 1,
          "title": "Maximum Observations",
          "type": "integer"
        },
        "maximum_relations": {
          "maximum": 200,
          "minimum": 0,
          "title": "Maximum Relations",
          "type": "integer"
        }
      },
      "required": [
        "maximum_observations",
        "maximum_claims",
        "maximum_evidence_links",
        "maximum_relations"
      ],
      "title": "ExtractionBudget",
      "type": "object"
    },
    "GroundedSourceSpan": {
      "additionalProperties": false,
      "properties": {
        "end": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "excerpt_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Excerpt Hash",
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/GroundingMode"
        },
        "path": {
          "anyOf": [
            {
              "maxLength": 1024,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "source": {
          "$ref": "#/$defs/SemanticSourceRef"
        },
        "start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        }
      },
      "required": [
        "source",
        "mode",
        "excerpt_hash"
      ],
      "title": "GroundedSourceSpan",
      "type": "object"
    },
    "GroundingMode": {
      "enum": [
        "typed_field",
        "artifact_bytes",
        "line_range",
        "event_field",
        "memory_field"
      ],
      "title": "GroundingMode",
      "type": "string"
    },
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "MemoryScope": {
      "additionalProperties": false,
      "properties": {
        "scope_id": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Scope Id",
          "type": "string"
        },
        "scope_type": {
          "$ref": "#/$defs/MemoryScopeType"
        }
      },
      "required": [
        "scope_type",
        "scope_id"
      ],
      "title": "MemoryScope",
      "type": "object"
    },
    "MemoryScopeType": {
      "enum": [
        "global",
        "project",
        "repository",
        "task",
        "session",
        "domain"
      ],
      "title": "MemoryScopeType",
      "type": "string"
    },
    "MemorySensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "MemorySensitivity",
      "type": "string"
    },
    "SemanticSourceRef": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "revision": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revision"
        },
        "source_id": {
          "format": "uuid",
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/SemanticSourceType"
        }
      },
      "required": [
        "source_type",
        "source_id",
        "content_hash"
      ],
      "title": "SemanticSourceRef",
      "type": "object"
    },
    "SemanticSourceType": {
      "enum": [
        "event",
        "artifact",
        "memory_revision",
        "task_run",
        "trajectory"
      ],
      "title": "SemanticSourceType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/semantic-extraction-request.schema.json",
  "additionalProperties": false,
  "properties": {
    "budget": {
      "$ref": "#/$defs/ExtractionBudget"
    },
    "registry_snapshot_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Registry Snapshot Hash",
      "type": "string"
    },
    "request_id": {
      "format": "uuid",
      "title": "Request Id",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "required_output_schema": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Required Output Schema",
      "type": "object"
    },
    "scope": {
      "$ref": "#/$defs/MemoryScope"
    },
    "sensitivity_ceiling": {
      "$ref": "#/$defs/MemorySensitivity"
    },
    "source_spans": {
      "items": {
        "$ref": "#/$defs/GroundedSourceSpan"
      },
      "maxItems": 16,
      "minItems": 1,
      "title": "Source Spans",
      "type": "array"
    }
  },
  "required": [
    "request_id",
    "source_spans",
    "registry_snapshot_hash",
    "scope",
    "sensitivity_ceiling",
    "budget",
    "required_output_schema",
    "requested_at"
  ],
  "title": "SemanticExtractionRequest",
  "type": "object"
}
