{
  "$defs": {
    "ExtractionDecisionOutcome": {
      "enum": [
        "accepted",
        "rejected",
        "requires_review"
      ],
      "title": "ExtractionDecisionOutcome",
      "type": "string"
    },
    "SemanticActor": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/SemanticActorType"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "SemanticActor",
      "type": "object"
    },
    "SemanticActorType": {
      "enum": [
        "user",
        "operator",
        "controller",
        "semantic_service",
        "approved_internal_service",
        "provider"
      ],
      "title": "SemanticActorType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/semantic-memory/extraction-decision.schema.json",
  "additionalProperties": false,
  "properties": {
    "decided_at": {
      "format": "date-time",
      "title": "Decided At",
      "type": "string"
    },
    "decided_by": {
      "$ref": "#/$defs/SemanticActor"
    },
    "extraction_id": {
      "format": "uuid",
      "title": "Extraction Id",
      "type": "string"
    },
    "outcome": {
      "$ref": "#/$defs/ExtractionDecisionOutcome"
    },
    "proposal_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Proposal Hash",
      "type": "string"
    },
    "reason_codes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Reason Codes",
      "type": "array"
    }
  },
  "required": [
    "extraction_id",
    "outcome",
    "proposal_hash",
    "reason_codes",
    "decided_at",
    "decided_by"
  ],
  "title": "ExtractionDecision",
  "type": "object"
}
