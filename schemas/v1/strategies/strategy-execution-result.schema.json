          "format": "uuid",
          "title": "Selection Id",
          "type": "string"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/StrategyOutcomeStatus"
