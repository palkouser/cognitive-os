        "task_run_id",
        "problem_signature",
        "strategy_id",
        "strategy_revision",
        "resolved_skills",
        "plan_instantiation_id",
        "plan_hash",
        "phase_executions",
        "status",
        "elapsed_ms",
        "started_at",
        "finished_at"
