{
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/ActorType"
        },
        "display_name": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        }
      },
      "required": [
        "actor_type",
        "actor_id"
      ],
      "title": "ActorRef",
      "type": "object"
    },
    "ActorType": {
      "enum": [
        "user",
        "agent",
        "model",
        "tool",
        "verifier",
        "system"
      ],
      "title": "ActorType",
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ContextBundleReference": {
      "additionalProperties": false,
      "properties": {
        "bundle_artifact_id": {
          "format": "uuid",
          "title": "Bundle Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "context_bundle_id": {
          "format": "uuid",
          "title": "Context Bundle Id",
          "type": "string"
        },
        "context_bundle_revision": {
          "minimum": 1,
          "title": "Context Bundle Revision",
          "type": "integer"
        },
        "rendered_context_artifact_id": {
          "format": "uuid",
          "title": "Rendered Context Artifact Id",
          "type": "string"
        },
        "source_snapshot_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Snapshot Hash",
          "type": "string"
        }
      },
      "required": [
        "context_bundle_id",
        "context_bundle_revision",
        "bundle_artifact_id",
        "rendered_context_artifact_id",
        "content_hash",
        "source_snapshot_hash"
      ],
      "title": "ContextBundleReference",
      "type": "object"
    },
    "ExecutionPlan": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "created_by": {
          "$ref": "#/$defs/ActorRef"
        },
        "plan_id": {
          "format": "uuid",
          "title": "Plan Id",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/PlanStepDefinition"
          },
          "minItems": 1,
          "title": "Steps",
          "type": "array"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "plan_id",
        "task_run_id",
        "version",
        "created_at",
        "created_by",
        "steps"
      ],
      "title": "ExecutionPlan",
      "type": "object"
    },
    "PlanStepDefinition": {
      "additionalProperties": false,
      "properties": {
        "depends_on": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "expected_output": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Output"
        },
        "required_tool_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Tool Ids",
          "type": "array"
        },
        "required_verifier_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Verifier Ids",
          "type": "array"
        },
        "sequence": {
          "minimum": 1,
          "title": "Sequence",
          "type": "integer"
        },
        "step_id": {
          "format": "uuid",
          "title": "Step Id",
          "type": "string"
        },
        "step_type": {
          "minLength": 1,
          "title": "Step Type",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "step_id",
        "sequence",
        "step_type",
        "title"
      ],
      "title": "PlanStepDefinition",
      "type": "object"
    },
    "ResolvedSkillBinding": {
      "additionalProperties": false,
      "properties": {
        "binding_id": {
          "minLength": 1,
          "title": "Binding Id",
          "type": "string"
        },
        "fallback": {
          "default": false,
          "title": "Fallback",
          "type": "boolean"
        },
        "package_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Package Hash",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        },
        "skill_id": {
          "format": "uuid",
          "title": "Skill Id",
          "type": "string"
        }
      },
      "required": [
        "binding_id",
        "skill_id",
        "revision",
        "package_hash"
      ],
      "title": "ResolvedSkillBinding",
      "type": "object"
    },
    "SkillProblemSignature": {
      "additionalProperties": false,
      "properties": {
        "problem_domain": {
          "minLength": 1,
          "title": "Problem Domain",
          "type": "string"
        },
        "relevant_artifact_types": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 32,
          "title": "Relevant Artifact Types",
          "type": "array"
        },
        "repository_language": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
