        "task_type": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Type"
        }
      },
      "required": [
        "problem_domain"
      ],
