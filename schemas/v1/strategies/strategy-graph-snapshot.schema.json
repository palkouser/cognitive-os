{
  "$defs": {
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    },
    "SkillRegistrySnapshot": {
      "additionalProperties": false,
      "properties": {
        "context_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Context Registry Hash",
          "type": "string"
        },
        "precondition_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Precondition Registry Hash",
          "type": "string"
        },
        "provider_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Provider Registry Hash",
          "type": "string"
        },
        "registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Registry Hash",
          "type": "string"
        },
        "tool_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Tool Registry Hash",
          "type": "string"
        },
        "verifier_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Verifier Registry Hash",
          "type": "string"
        }
      },
      "required": [
        "registry_hash",
        "precondition_registry_hash",
        "context_registry_hash",
        "tool_registry_hash",
        "verifier_registry_hash",
        "provider_registry_hash"
      ],
      "title": "SkillRegistrySnapshot",
      "type": "object"
    },
    "StrategyEdge": {
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "edge_hash": {
          "default": "",
          "title": "Edge Hash",
          "type": "string"
        },
        "edge_id": {
          "format": "uuid",
          "title": "Edge Id",
          "type": "string"
        },
        "edge_type": {
          "$ref": "#/$defs/StrategyEdgeType"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/StrategySourceRef"
          },
          "maxItems": 64,
          "minItems": 1,
          "title": "Source Refs",
          "type": "array"
        },
        "source_revision": {
          "minimum": 1,
          "title": "Source Revision",
          "type": "integer"
        },
        "source_strategy_id": {
          "format": "uuid",
          "title": "Source Strategy Id",
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/StrategyTargetReference"
        },
        "weight": {
          "default": "1",
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Weight",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "source_strategy_id",
        "source_revision",
        "target",
        "edge_type",
        "source_refs",
        "created_at"
      ],
      "title": "StrategyEdge",
      "type": "object"
    },
    "StrategyEdgeType": {
      "enum": [
        "applies_to_problem_class",
        "uses_skill",
        "allows_fallback_skill",
        "uses_tool",
        "uses_model_role",
        "requires_verifier",
        "uses_context_profile",
        "has_phase",
        "phase_precedes",
        "phase_branches_to",
        "fallback_to",
        "specializes",
        "generalizes",
        "supersedes",
        "derived_from",
        "corrects",
        "failed_with",
        "succeeded_with",
        "observed_in",
        "produced_outcome"
      ],
      "title": "StrategyEdgeType",
      "type": "string"
    },
    "StrategyRegistrySnapshot": {
      "additionalProperties": false,
      "properties": {
        "context_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Context Registry Hash",
          "type": "string"
        },
        "problem_class_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Problem Class Registry Hash",
          "type": "string"
        },
        "provider_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Provider Registry Hash",
          "type": "string"
        },
        "skill_registry": {
          "$ref": "#/$defs/SkillRegistrySnapshot"
        },
        "strategy_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Strategy Registry Hash",
          "type": "string"
        },
        "target_resolver_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Target Resolver Registry Hash",
          "type": "string"
        },
        "tool_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Tool Registry Hash",
          "type": "string"
        },
        "verifier_registry_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Verifier Registry Hash",
          "type": "string"
        }
      },
      "required": [
        "strategy_registry_hash",
        "problem_class_registry_hash",
        "target_resolver_registry_hash",
        "skill_registry",
        "tool_registry_hash",
        "verifier_registry_hash",
        "provider_registry_hash",
        "context_registry_hash"
      ],
      "title": "StrategyRegistrySnapshot",
      "type": "object"
    },
    "StrategyScope": {
      "additionalProperties": false,
      "properties": {
        "scope_id": {
          "minLength": 1,
          "title": "Scope Id",
          "type": "string"
        },
        "scope_type": {
          "$ref": "#/$defs/StrategyScopeType"
        }
      },
      "required": [
        "scope_type",
        "scope_id"
      ],
      "title": "StrategyScope",
      "type": "object"
    },
    "StrategyScopeType": {
      "enum": [
        "global",
        "project",
        "repository",
        "domain"
      ],
      "title": "StrategyScopeType",
      "type": "string"
    },
    "StrategySourceRef": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_revision": {
          "minLength": 1,
          "title": "Source Revision",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/StrategySourceType"
        }
      },
      "required": [
        "source_type",
        "source_id",
        "source_revision",
        "content_hash"
      ],
      "title": "StrategySourceRef",
      "type": "object"
    },
    "StrategySourceType": {
      "enum": [
        "manual",
        "repository",
        "artifact",
        "semantic_claim",
        "task_outcome"
      ],
      "title": "StrategySourceType",
      "type": "string"
    },
    "StrategyTargetReference": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "scope": {
          "anyOf": [
            {
              "$ref": "#/$defs/StrategyScope"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "target_id": {
          "minLength": 1,
          "title": "Target Id",
          "type": "string"
        },
        "target_revision": {
          "minLength": 1,
          "title": "Target Revision",
          "type": "string"
        },
        "target_type": {
          "$ref": "#/$defs/StrategyTargetType"
        }
      },
      "required": [
        "target_type",
        "target_id",
        "target_revision",
        "content_hash"
      ],
      "title": "StrategyTargetReference",
      "type": "object"
    },
    "StrategyTargetType": {
      "enum": [
        "strategy_revision",
        "problem_class",
        "failure_mode",
        "phase",
        "skill_revision",
        "tool",
        "model_role",
        "verifier",
        "context_profile",
        "task_run",
        "controller_plan",
        "context_bundle",
        "correction_event",
        "acceptance_decision",
        "outcome",
        "artifact",
        "semantic_claim_revision"
      ],
      "title": "StrategyTargetType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/strategies/strategy-graph-snapshot.schema.json",
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/StrategyEdge"
      },
      "maxItems": 10000,
      "title": "Edges",
      "type": "array"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/StrategyTargetReference"
      },
      "maxItems": 5000,
      "title": "Nodes",
      "type": "array"
    },
    "query_parameters": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Query Parameters",
      "type": "object"
    },
    "registry_snapshot": {
      "$ref": "#/$defs/StrategyRegistrySnapshot"
    },
    "snapshot_hash": {
      "default": "",
      "title": "Snapshot Hash",
      "type": "string"
    },
    "snapshot_id": {
      "format": "uuid",
      "title": "Snapshot Id",
      "type": "string"
    }
  },
  "required": [
    "snapshot_id",
    "nodes",
    "edges",
    "query_parameters",
    "registry_snapshot",
    "created_at"
  ],
  "title": "StrategyGraphSnapshot",
  "type": "object"
}
