{
  "$defs": {
    "StrategyActor": {
      "additionalProperties": false,
      "properties": {
        "creator_id": {
          "minLength": 1,
          "title": "Creator Id",
          "type": "string"
        },
        "creator_type": {
          "$ref": "#/$defs/StrategyCreatorType"
        }
      },
      "required": [
        "creator_type",
        "creator_id"
      ],
      "title": "StrategyActor",
      "type": "object"
    },
    "StrategyCreatorType": {
      "enum": [
        "operator",
        "user",
        "import_service",
        "system",
        "provider"
      ],
      "title": "StrategyCreatorType",
      "type": "string"
    },
    "StrategyScope": {
      "additionalProperties": false,
      "properties": {
        "scope_id": {
          "minLength": 1,
          "title": "Scope Id",
          "type": "string"
        },
        "scope_type": {
          "$ref": "#/$defs/StrategyScopeType"
        }
      },
      "required": [
        "scope_type",
        "scope_id"
      ],
      "title": "StrategyScope",
      "type": "object"
    },
    "StrategyScopeType": {
      "enum": [
        "global",
        "project",
        "repository",
        "domain"
      ],
      "title": "StrategyScopeType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/strategies/strategy-identity.schema.json",
  "additionalProperties": false,
  "properties": {
    "canonical_name": {
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "title": "Canonical Name",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "$ref": "#/$defs/StrategyActor"
    },
    "problem_class_id": {
      "minLength": 1,
      "title": "Problem Class Id",
      "type": "string"
    },
    "scope": {
      "$ref": "#/$defs/StrategyScope"
    },
    "strategy_id": {
      "format": "uuid",
      "title": "Strategy Id",
      "type": "string"
    }
  },
  "required": [
    "strategy_id",
    "canonical_name",
    "scope",
    "problem_class_id",
    "created_at",
    "created_by"
  ],
  "title": "StrategyIdentity",
  "type": "object"
}
