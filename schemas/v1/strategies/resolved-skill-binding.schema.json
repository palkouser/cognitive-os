{
  "$id": "https://cognitive-os.local/schemas/v1/strategies/resolved-skill-binding.schema.json",
  "additionalProperties": false,
  "properties": {
    "binding_id": {
      "minLength": 1,
      "title": "Binding Id",
      "type": "string"
    },
    "fallback": {
      "default": false,
      "title": "Fallback",
      "type": "boolean"
    },
    "package_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Package Hash",
      "type": "string"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "skill_id": {
      "format": "uuid",
      "title": "Skill Id",
      "type": "string"
    }
  },
  "required": [
    "binding_id",
    "skill_id",
    "revision",
    "package_hash"
  ],
  "title": "ResolvedSkillBinding",
  "type": "object"
}
