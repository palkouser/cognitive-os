{
  "$defs": {
    "ResolvedSkillBinding": {
      "additionalProperties": false,
      "properties": {
        "binding_id": {
          "minLength": 1,
          "title": "Binding Id",
          "type": "string"
        },
        "fallback": {
          "default": false,
          "title": "Fallback",
          "type": "boolean"
        },
        "package_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Package Hash",
          "type": "string"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        },
        "skill_id": {
          "format": "uuid",
          "title": "Skill Id",
          "type": "string"
        }
      },
      "required": [
        "binding_id",
        "skill_id",
        "revision",
        "package_hash"
      ],
      "title": "ResolvedSkillBinding",
      "type": "object"
    },
    "StrategyBudgetProfile": {
      "additionalProperties": false,
      "properties": {
        "maximum_context_builds": {
          "default": 8,
          "maximum": 8,
          "minimum": 0,
          "title": "Maximum Context Builds",
          "type": "integer"
        },
        "maximum_context_tokens": {
          "default": 32768,
          "maximum": 1000000,
          "minimum": 1,
          "title": "Maximum Context Tokens",
          "type": "integer"
        },
        "maximum_execution_seconds": {
          "default": 3600,
          "maximum": 3600,
          "minimum": 1,
          "title": "Maximum Execution Seconds",
          "type": "integer"
        },
        "maximum_provider_calls": {
          "default": 8,
          "maximum": 8,
          "minimum": 0,
          "title": "Maximum Provider Calls",
          "type": "integer"
        },
        "maximum_repairs": {
          "default": 3,
          "maximum": 3,
          "minimum": 0,
          "title": "Maximum Repairs",
          "type": "integer"
        },
        "maximum_steps": {
          "default": 128,
          "maximum": 128,
          "minimum": 1,
          "title": "Maximum Steps",
          "type": "integer"
        },
        "maximum_tool_calls": {
          "default": 32,
          "maximum": 32,
          "minimum": 0,
          "title": "Maximum Tool Calls",
          "type": "integer"
        }
      },
      "title": "StrategyBudgetProfile",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/strategies/strategy-plan-step-binding.schema.json",
  "additionalProperties": false,
  "properties": {
    "branch_ids": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Branch Ids",
      "type": "array"
    },
    "context_profile_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Context Profile Id"
    },
    "effective_budget": {
      "$ref": "#/$defs/StrategyBudgetProfile"
    },
    "fallback_provenance": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Fallback Provenance",
      "type": "array"
    },
    "model_role_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Role Id"
    },
    "phase_id": {
      "minLength": 1,
      "title": "Phase Id",
      "type": "string"
    },
    "skill_binding": {
      "anyOf": [
        {
          "$ref": "#/$defs/ResolvedSkillBinding"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "step_id": {
      "format": "uuid",
      "title": "Step Id",
      "type": "string"
    },
    "tool_capabilities": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Tool Capabilities",
      "type": "array"
    },
    "verifier_capabilities": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Verifier Capabilities",
      "type": "array"
    }
  },
  "required": [
    "step_id",
    "phase_id",
    "effective_budget"
  ],
  "title": "StrategyPlanStepBinding",
  "type": "object"
}
