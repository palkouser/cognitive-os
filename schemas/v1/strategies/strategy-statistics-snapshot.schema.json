{
  "$defs": {
    "StrategyStatistics": {
      "additionalProperties": false,
      "properties": {
        "accepted": {
          "minimum": 0,
          "title": "Accepted",
          "type": "integer"
        },
        "cancelled": {
          "minimum": 0,
          "title": "Cancelled",
          "type": "integer"
        },
        "cohort_id": {
          "minLength": 1,
          "title": "Cohort Id",
          "type": "string"
        },
        "confidence_formula_version": {
          "default": "wilson-v1",
          "minLength": 1,
          "title": "Confidence Formula Version",
          "type": "string"
        },
        "confidence_lower_bound": {
          "default": "0",
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Confidence Lower Bound",
          "type": "string"
        },
        "context_builds": {
          "minimum": 0,
          "title": "Context Builds",
          "type": "integer"
        },
        "elapsed_ms": {
          "minimum": 0,
          "title": "Elapsed Ms",
          "type": "integer"
        },
        "executions": {
          "minimum": 0,
          "title": "Executions",
          "type": "integer"
        },
        "fallbacks": {
          "minimum": 0,
          "title": "Fallbacks",
          "type": "integer"
        },
        "infrastructure_failures": {
          "minimum": 0,
          "title": "Infrastructure Failures",
          "type": "integer"
        },
        "policy_denied": {
          "minimum": 0,
          "title": "Policy Denied",
          "type": "integer"
        },
        "projection_hash": {
          "default": "",
          "title": "Projection Hash",
          "type": "string"
        },
        "projection_revision": {
          "minimum": 1,
          "title": "Projection Revision",
          "type": "integer"
        },
        "provider_calls": {
          "minimum": 0,
          "title": "Provider Calls",
          "type": "integer"
        },
        "rejected": {
          "minimum": 0,
          "title": "Rejected",
          "type": "integer"
        },
        "repairs": {
          "minimum": 0,
          "title": "Repairs",
          "type": "integer"
        },
        "revision": {
          "minimum": 1,
          "title": "Revision",
          "type": "integer"
        },
        "safety_failures": {
          "minimum": 0,
          "title": "Safety Failures",
          "type": "integer"
        },
        "source_outcome_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Source Outcome Ids",
          "type": "array"
        },
        "sparse_sample": {
          "title": "Sparse Sample",
          "type": "boolean"
        },
        "strategy_id": {
          "format": "uuid",
          "title": "Strategy Id",
          "type": "string"
        },
        "token_usage": {
          "minimum": 0,
          "title": "Token Usage",
          "type": "integer"
        },
        "tool_calls": {
          "minimum": 0,
          "title": "Tool Calls",
          "type": "integer"
        },
        "unverifiable": {
          "minimum": 0,
          "title": "Unverifiable",
          "type": "integer"
        },
        "verifier_quality": {
          "default": "0",
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Verifier Quality",
          "type": "string"
        }
      },
      "required": [
        "strategy_id",
        "revision",
        "cohort_id",
        "projection_revision",
        "executions",
        "accepted",
        "rejected",
        "unverifiable",
        "cancelled",
        "policy_denied",
        "infrastructure_failures",
        "repairs",
        "fallbacks",
        "provider_calls",
        "tool_calls",
        "context_builds",
        "token_usage",
        "elapsed_ms",
        "safety_failures",
        "sparse_sample",
        "source_outcome_ids"
      ],
      "title": "StrategyStatistics",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/strategies/strategy-statistics-snapshot.schema.json",
  "additionalProperties": false,
  "properties": {
    "snapshot_hash": {
      "default": "",
      "title": "Snapshot Hash",
      "type": "string"
    },
    "statistics": {
      "items": {
        "$ref": "#/$defs/StrategyStatistics"
      },
      "title": "Statistics",
      "type": "array"
    }
  },
  "required": [
    "statistics"
  ],
  "title": "StrategyStatisticsSnapshot",
  "type": "object"
}
