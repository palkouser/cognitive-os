{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "format": "uuid",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_key": {
          "minLength": 1,
          "title": "Storage Key",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "media_type",
        "content_hash",
        "size_bytes",
        "storage_key",
        "created_at"
      ],
      "title": "ArtifactRef",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/strategies/strategy-comparison-result.schema.json",
  "additionalProperties": false,
  "properties": {
    "comparison_hash": {
      "default": "",
      "title": "Comparison Hash",
      "type": "string"
    },
    "comparison_id": {
      "format": "uuid",
      "title": "Comparison Id",
      "type": "string"
    },
    "report_artifact": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "source_outcome_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Source Outcome Ids",
      "type": "array"
    },
    "statistics_delta": {
      "additionalProperties": {
        "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
        "type": "string"
      },
      "title": "Statistics Delta",
      "type": "object"
    },
    "structural_changes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Structural Changes",
      "type": "array"
    },
    "sufficient_sample": {
      "title": "Sufficient Sample",
      "type": "boolean"
    }
  },
  "required": [
    "comparison_id",
    "structural_changes",
    "statistics_delta",
    "sufficient_sample",
    "source_outcome_ids"
  ],
  "title": "StrategyComparisonResult",
  "type": "object"
}
