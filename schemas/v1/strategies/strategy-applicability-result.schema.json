{
  "$defs": {
    "StrategyApplicabilityEvidence": {
      "additionalProperties": false,
      "properties": {
        "condition_id": {
          "minLength": 1,
          "title": "Condition Id",
          "type": "string"
        },
        "evidence_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Hash",
          "type": "string"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "reason_code": {
          "minLength": 1,
          "title": "Reason Code",
          "type": "string"
        }
      },
      "required": [
        "condition_id",
        "passed",
        "reason_code",
        "evidence_hash"
      ],
      "title": "StrategyApplicabilityEvidence",
      "type": "object"
    },
    "StrategyApplicabilityStatus": {
      "enum": [
        "applicable",
        "inapplicable",
        "requires_approval",
        "unavailable",
        "insufficiently_measured",
        "invalid"
      ],
      "title": "StrategyApplicabilityStatus",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/strategies/strategy-applicability-result.schema.json",
  "additionalProperties": false,
  "properties": {
    "evaluation_hash": {
      "default": "",
      "title": "Evaluation Hash",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/StrategyApplicabilityEvidence"
      },
      "title": "Evidence",
      "type": "array"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/StrategyApplicabilityStatus"
    },
    "strategy_id": {
      "format": "uuid",
      "title": "Strategy Id",
      "type": "string"
    }
  },
  "required": [
    "strategy_id",
    "revision",
    "status",
    "evidence"
  ],
  "title": "StrategyApplicabilityResult",
  "type": "object"
}
