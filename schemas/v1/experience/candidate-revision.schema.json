{
  "$defs": {
    "ExperienceCandidateStatus": {
      "enum": [
        "proposed",
        "validated",
        "rejected",
        "routed",
        "superseded"
      ],
      "title": "ExperienceCandidateStatus",
      "type": "string"
    }
  },
