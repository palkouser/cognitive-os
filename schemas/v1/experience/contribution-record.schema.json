{
  "$defs": {
    "ContributionSubjectType": {
      "enum": [
        "model_call",
        "tool_call",
        "skill_revision",
        "strategy_revision",
        "context_bundle",
        "context_candidate",
        "memory_revision",
        "semantic_claim_revision",
        "user_correction",
        "verifier",
        "artifact"
      ],
      "title": "ContributionSubjectType",
      "type": "string"
    },
    "ContributionType": {
      "enum": [
        "helpful",
        "neutral",
        "harmful",
        "unknown"
      ],
      "title": "ContributionType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/experience/contribution-record.schema.json",
  "additionalProperties": false,
  "properties": {
    "assessment": {
      "$ref": "#/$defs/ContributionType"
    },
    "causal_strength": {
      "default": "correlated",
      "minLength": 1,
      "title": "Causal Strength",
      "type": "string"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "contribution_id": {
      "format": "uuid",
      "title": "Contribution Id",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "maxItems": 64,
      "minItems": 1,
      "title": "Evidence Refs",
      "type": "array"
    },
    "limitations": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "reason": {
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "subject_id": {
      "minLength": 1,
      "title": "Subject Id",
      "type": "string"
    },
    "subject_type": {
      "$ref": "#/$defs/ContributionSubjectType"
    }
  },
  "required": [
    "contribution_id",
    "subject_type",
    "subject_id",
    "assessment",
    "evidence_refs",
    "reason"
  ],
  "title": "ContributionRecord",
  "type": "object"
}
