{
  "$defs": {
    "VerificationCapabilityResult": {
      "additionalProperties": false,
      "properties": {
        "capability": {
          "minLength": 1,
          "title": "Capability",
          "type": "string"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "evidence_refs": {
          "default": [],
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "capability",
        "passed",
        "reason"
      ],
      "title": "VerificationCapabilityResult",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/experience/experience-verifier-bundle.schema.json",
  "additionalProperties": false,
  "properties": {
    "bundle_id": {
      "format": "uuid",
      "title": "Bundle Id",
      "type": "string"
    },
    "compilation_id": {
      "format": "uuid",
      "title": "Compilation Id",
      "type": "string"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "registry_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Registry Hash",
      "type": "string"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/VerificationCapabilityResult"
      },
      "minItems": 1,
      "title": "Results",
      "type": "array"
    }
  },
  "required": [
    "bundle_id",
    "compilation_id",
    "registry_hash",
    "results",
    "created_at"
  ],
  "title": "ExperienceVerifierBundle",
  "type": "object"
}
