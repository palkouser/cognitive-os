{
  "$id": "https://cognitive-os.local/schemas/v1/experience/candidate-routing-envelope.schema.json",
  "additionalProperties": false,
  "properties": {
    "artifact_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Artifact Hash",
      "type": "string"
    },
    "candidate_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Candidate Hash",
      "type": "string"
    },
    "candidate_id": {
      "format": "uuid",
      "title": "Candidate Id",
      "type": "string"
    },
    "candidate_revision": {
      "minimum": 1,
      "title": "Candidate Revision",
      "type": "integer"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "requested_by": {
      "minLength": 1,
      "title": "Requested By",
      "type": "string"
    },
    "target_subsystem": {
      "minLength": 1,
      "title": "Target Subsystem",
      "type": "string"
    }
  },
  "required": [
    "candidate_id",
    "candidate_revision",
    "candidate_hash",
    "artifact_hash",
    "target_subsystem",
    "requested_by",
    "created_at"
  ],
  "title": "CandidateRoutingEnvelope",
  "type": "object"
}
