{
  "$defs": {
    "CodeContextMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "base_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Base Commit",
          "type": "string"
        },
        "bounded_excerpt": {
          "anyOf": [
            {
              "maxLength": 16384,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bounded Excerpt"
        },
        "changed_paths": {
          "default": [],
          "items": {
            "maxLength": 512,
            "type": "string"
          },
          "title": "Changed Paths",
          "type": "array"
        },
        "context_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Context Hash",
          "type": "string"
        },
        "diff_artifact_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Diff Artifact Id"
        },
        "excerpt_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excerpt Hash"
        },
        "memory_type": {
          "const": "code_context",
          "default": "code_context",
          "title": "Memory Type",
          "type": "string"
        },
        "repository_identity": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Repository Identity",
          "type": "string"
        },
        "repository_profile": {
          "maxLength": 4096,
          "title": "Repository Profile",
          "type": "string"
        },
        "symbol_references": {
          "default": [],
          "items": {
            "maxLength": 512,
            "type": "string"
          },
          "title": "Symbol References",
          "type": "array"
        }
      },
      "required": [
        "repository_identity",
        "base_commit",
        "repository_profile",
        "context_hash"
      ],
      "title": "CodeContextMemoryContent",
      "type": "object"
    },
    "CorrectionMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "corrected_memory_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Corrected Memory Id"
        },
        "corrected_revision": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Corrected Revision"
        },
        "correction": {
          "maxLength": 16384,
          "title": "Correction",
          "type": "string"
        },
        "memory_type": {
          "const": "correction",
          "default": "correction",
          "title": "Memory Type",
          "type": "string"
        }
      },
      "required": [
        "correction"
      ],
      "title": "CorrectionMemoryContent",
      "type": "object"
    },
    "DecisionMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "decision": {
          "maxLength": 16384,
          "title": "Decision",
          "type": "string"
        },
        "memory_type": {
          "const": "decision",
          "default": "decision",
          "title": "Memory Type",
          "type": "string"
        },
        "rationale": {
          "maxLength": 16384,
          "title": "Rationale",
          "type": "string"
        },
        "selected_by": {
          "minLength": 1,
          "title": "Selected By",
          "type": "string"
        }
      },
      "required": [
        "decision",
        "rationale",
        "selected_by"
      ],
      "title": "DecisionMemoryContent",
      "type": "object"
    },
    "EpisodeMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "artifact_ids": {
          "default": [],
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Artifact Ids",
          "type": "array"
        },
        "base_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Base Commit",
          "type": "string"
        },
        "memory_type": {
          "const": "episode",
          "default": "episode",
          "title": "Memory Type",
          "type": "string"
        },
        "outcome": {
          "minLength": 1,
          "title": "Outcome",
          "type": "string"
        },
        "patch_attempt_count": {
          "minimum": 0,
          "title": "Patch Attempt Count",
          "type": "integer"
        },
        "problem_summary": {
          "maxLength": 8192,
          "title": "Problem Summary",
          "type": "string"
        },
        "remaining_risks": {
          "default": [],
          "items": {
            "maxLength": 2048,
            "type": "string"
          },
          "title": "Remaining Risks",
          "type": "array"
        },
        "repair_count": {
          "minimum": 0,
          "title": "Repair Count",
          "type": "integer"
        },
        "repository_identity": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Repository Identity",
          "type": "string"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "trajectory_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Trajectory Hash",
          "type": "string"
        },
        "verifier_summary": {
          "maxLength": 8192,
          "title": "Verifier Summary",
          "type": "string"
        }
      },
      "required": [
        "task_run_id",
        "title",
        "problem_summary",
        "repository_identity",
        "base_commit",
        "outcome",
        "patch_attempt_count",
        "repair_count",
        "verifier_summary",
        "trajectory_hash"
      ],
      "title": "EpisodeMemoryContent",
      "type": "object"
    },
    "FailurePatternMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "failed_evidence": {
          "maxLength": 8192,
          "title": "Failed Evidence",
          "type": "string"
        },
        "memory_type": {
          "const": "failure_pattern",
          "default": "failure_pattern",
          "title": "Memory Type",
          "type": "string"
        },
        "successful_correction": {
          "maxLength": 8192,
          "title": "Successful Correction",
          "type": "string"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        }
      },
      "required": [
        "failed_evidence",
        "successful_correction",
        "task_run_id"
      ],
      "title": "FailurePatternMemoryContent",
      "type": "object"
    },
    "MemoryCreator": {
      "additionalProperties": false,
      "properties": {
        "creator_id": {
          "minLength": 1,
          "title": "Creator Id",
          "type": "string"
        },
        "creator_type": {
          "$ref": "#/$defs/MemoryCreatorType"
        }
      },
      "required": [
        "creator_type",
        "creator_id"
      ],
      "title": "MemoryCreator",
      "type": "object"
    },
    "MemoryCreatorType": {
      "enum": [
        "user",
        "operator",
        "controller",
        "ingestion_service",
        "approved_internal_service",
        "provider"
      ],
      "title": "MemoryCreatorType",
      "type": "string"
    },
    "MemoryProvenanceBundle": {
      "additionalProperties": false,
      "properties": {
        "sources": {
          "items": {
            "$ref": "#/$defs/MemorySourceRef"
          },
          "maxItems": 64,
          "minItems": 1,
          "title": "Sources",
          "type": "array"
        }
      },
      "required": [
        "sources"
      ],
      "title": "MemoryProvenanceBundle",
      "type": "object"
    },
    "MemoryScope": {
      "additionalProperties": false,
      "properties": {
        "scope_id": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Scope Id",
          "type": "string"
        },
        "scope_type": {
          "$ref": "#/$defs/MemoryScopeType"
        }
      },
      "required": [
        "scope_type",
        "scope_id"
      ],
      "title": "MemoryScope",
      "type": "object"
    },
    "MemoryScopeType": {
      "enum": [
        "global",
        "project",
        "repository",
        "task",
        "session",
        "domain"
      ],
      "title": "MemoryScopeType",
      "type": "string"
    },
    "MemorySensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "MemorySensitivity",
      "type": "string"
    },
    "MemorySourceIdentity": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Hash"
        },
        "memory_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Memory Id"
        },
        "revision": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revision"
        },
        "source_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        },
        "source_type": {
          "$ref": "#/$defs/MemorySourceType"
        }
      },
      "required": [
        "source_type"
      ],
      "title": "MemorySourceIdentity",
      "type": "object"
    },
    "MemorySourceRef": {
      "additionalProperties": false,
      "properties": {
        "identity": {
          "$ref": "#/$defs/MemorySourceIdentity"
        },
        "relationship": {
          "default": "derived_from",
          "maxLength": 128,
          "minLength": 1,
          "title": "Relationship",
          "type": "string"
        },
        "source_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Hash",
          "type": "string"
        }
      },
      "required": [
        "identity",
        "source_hash"
      ],
      "title": "MemorySourceRef",
      "type": "object"
    },
    "MemorySourceType": {
      "enum": [
        "event",
        "artifact",
        "task_run",
        "acceptance_decision",
        "verifier_result",
        "coding_trajectory",
        "user_correction",
        "memory_revision",
        "selected_decision"
      ],
      "title": "MemorySourceType",
      "type": "string"
    },
    "MemoryStatus": {
      "enum": [
        "candidate",
        "verified",
        "superseded",
        "retracted",
        "expired"
      ],
      "title": "MemoryStatus",
      "type": "string"
    },
    "MemoryTransitionReason": {
      "enum": [
        "created",
        "content_revised",
        "metadata_revised",
        "authoritative_evidence_verified",
        "superseded_by_successor",
        "user_correction",
        "source_retracted",
        "policy_retraction",
        "retention_expired",
        "explicit_expiry"
      ],
      "title": "MemoryTransitionReason",
      "type": "string"
    },
    "MemoryType": {
      "enum": [
        "episode",
        "observation",
        "decision",
        "correction",
        "task_summary",
        "code_context",
        "verification_summary",
        "failure_pattern",
        "user_instruction"
      ],
      "title": "MemoryType",
      "type": "string"
    },
    "ObservationMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "evidence_summary": {
          "maxLength": 8192,
          "title": "Evidence Summary",
          "type": "string"
        },
        "memory_type": {
          "const": "observation",
          "default": "observation",
          "title": "Memory Type",
          "type": "string"
        },
        "observation": {
          "maxLength": 16384,
          "title": "Observation",
          "type": "string"
        }
      },
      "required": [
        "observation",
        "evidence_summary"
      ],
      "title": "ObservationMemoryContent",
      "type": "object"
    },
    "TaskSummaryMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "default": [],
          "items": {
            "maxLength": 2048,
            "type": "string"
          },
          "title": "Constraints",
          "type": "array"
        },
        "goal": {
          "maxLength": 8192,
          "title": "Goal",
          "type": "string"
        },
        "memory_type": {
          "const": "task_summary",
          "default": "task_summary",
          "title": "Memory Type",
          "type": "string"
        },
        "result": {
          "maxLength": 8192,
          "title": "Result",
          "type": "string"
        },
        "review_status": {
          "minLength": 1,
          "title": "Review Status",
          "type": "string"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        }
      },
      "required": [
        "task_run_id",
        "goal",
        "result",
        "review_status"
      ],
      "title": "TaskSummaryMemoryContent",
      "type": "object"
    },
    "UserInstructionMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "instruction": {
          "maxLength": 16384,
          "title": "Instruction",
          "type": "string"
        },
        "instruction_scope": {
          "minLength": 1,
          "title": "Instruction Scope",
          "type": "string"
        },
        "memory_type": {
          "const": "user_instruction",
          "default": "user_instruction",
          "title": "Memory Type",
          "type": "string"
        }
      },
      "required": [
        "instruction",
        "instruction_scope"
      ],
      "title": "UserInstructionMemoryContent",
      "type": "object"
    },
    "VerificationSummaryMemoryContent": {
      "additionalProperties": false,
      "properties": {
        "acceptance_decision_id": {
          "format": "uuid",
          "title": "Acceptance Decision Id",
          "type": "string"
        },
        "memory_type": {
          "const": "verification_summary",
          "default": "verification_summary",
          "title": "Memory Type",
          "type": "string"
        },
        "optional_results": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Optional Results",
          "type": "array"
        },
        "registry_snapshot_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Registry Snapshot Hash",
          "type": "string"
        },
        "required_failed": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Failed",
          "type": "array"
        },
        "required_passed": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Passed",
          "type": "array"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        },
        "verifier_errors": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Verifier Errors",
          "type": "array"
        }
      },
      "required": [
        "task_run_id",
        "acceptance_decision_id",
        "registry_snapshot_hash"
      ],
      "title": "VerificationSummaryMemoryContent",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/memory/memory-write-request.schema.json",
  "additionalProperties": false,
  "properties": {
    "actor": {
      "$ref": "#/$defs/MemoryCreator"
    },
    "automatic": {
      "default": false,
      "title": "Automatic",
      "type": "boolean"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "content": {
      "discriminator": {
        "mapping": {
          "code_context": "#/$defs/CodeContextMemoryContent",
          "correction": "#/$defs/CorrectionMemoryContent",
          "decision": "#/$defs/DecisionMemoryContent",
          "episode": "#/$defs/EpisodeMemoryContent",
          "failure_pattern": "#/$defs/FailurePatternMemoryContent",
          "observation": "#/$defs/ObservationMemoryContent",
          "task_summary": "#/$defs/TaskSummaryMemoryContent",
          "user_instruction": "#/$defs/UserInstructionMemoryContent",
          "verification_summary": "#/$defs/VerificationSummaryMemoryContent"
        },
        "propertyName": "memory_type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/EpisodeMemoryContent"
        },
        {
          "$ref": "#/$defs/TaskSummaryMemoryContent"
        },
        {
          "$ref": "#/$defs/VerificationSummaryMemoryContent"
        },
        {
          "$ref": "#/$defs/CodeContextMemoryContent"
        },
        {
          "$ref": "#/$defs/CorrectionMemoryContent"
        },
        {
          "$ref": "#/$defs/DecisionMemoryContent"
        },
        {
          "$ref": "#/$defs/ObservationMemoryContent"
        },
        {
          "$ref": "#/$defs/FailurePatternMemoryContent"
        },
        {
          "$ref": "#/$defs/UserInstructionMemoryContent"
        }
      ],
      "title": "Content"
    },
    "expected_revision": {
      "const": 0,
      "default": 0,
      "title": "Expected Revision",
      "type": "integer"
    },
    "idempotency_key": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "memory_id": {
      "format": "uuid",
      "title": "Memory Id",
      "type": "string"
    },
    "memory_type": {
      "$ref": "#/$defs/MemoryType"
    },
    "provenance": {
      "$ref": "#/$defs/MemoryProvenanceBundle"
    },
    "reason": {
      "$ref": "#/$defs/MemoryTransitionReason",
      "default": "created"
    },
    "request_id": {
      "format": "uuid",
      "title": "Request Id",
      "type": "string"
    },
    "salience": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Salience",
      "type": "number"
    },
    "scope": {
      "$ref": "#/$defs/MemoryScope"
    },
    "sensitivity": {
      "$ref": "#/$defs/MemorySensitivity"
    },
    "status": {
      "$ref": "#/$defs/MemoryStatus",
      "default": "candidate"
    },
    "title": {
      "maxLength": 1024,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "request_id",
    "idempotency_key",
    "memory_id",
    "memory_type",
    "scope",
    "title",
    "content",
    "confidence",
    "salience",
    "sensitivity",
    "provenance",
    "actor"
  ],
  "title": "MemoryWriteRequest",
  "type": "object"
}
