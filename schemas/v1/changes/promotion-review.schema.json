{
  "$id": "https://cognitive-os.local/schemas/v1/changes/promotion-review.schema.json",
  "additionalProperties": false,
  "properties": {
    "approved": {
      "title": "Approved",
      "type": "boolean"
    },
    "approver": {
      "minLength": 1,
      "title": "Approver",
      "type": "string"
    },
    "approver_authority": {
      "minLength": 1,
      "title": "Approver Authority",
      "type": "string"
    },
    "assessment_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Assessment Hash",
      "type": "string"
    },
    "candidate_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Candidate Hash",
      "type": "string"
    },
    "candidate_id": {
      "format": "uuid",
      "title": "Candidate Id",
      "type": "string"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "experiment_id": {
      "format": "uuid",
      "title": "Experiment Id",
      "type": "string"
    },
    "expires_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expires At"
    },
    "rationale": {
      "minLength": 1,
      "title": "Rationale",
      "type": "string"
    },
    "review_id": {
      "format": "uuid",
      "title": "Review Id",
      "type": "string"
    },
    "revoked": {
      "default": false,
      "title": "Revoked",
      "type": "boolean"
    },
    "target_authority": {
      "minLength": 1,
      "title": "Target Authority",
      "type": "string"
    }
  },
  "required": [
    "review_id",
    "experiment_id",
    "candidate_id",
    "candidate_hash",
    "assessment_hash",
    "approver",
    "approver_authority",
    "approved",
    "target_authority",
    "rationale",
    "created_at"
  ],
  "title": "PromotionReview",
  "type": "object"
}
