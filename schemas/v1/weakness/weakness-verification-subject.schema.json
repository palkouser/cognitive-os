{
  "$defs": {
    "JsonPrimitive": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "JsonValue": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonPrimitive"
        },
        {
          "items": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "array"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/weakness/weakness-verification-subject.schema.json",
  "additionalProperties": false,
  "properties": {
    "bounded_metadata": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "propertyNames": {
        "minLength": 1
      },
      "title": "Bounded Metadata",
      "type": "object"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "related_hashes": {
      "default": [],
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Related Hashes",
      "type": "array"
    },
    "subject_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Subject Hash",
      "type": "string"
    },
    "subject_id": {
      "minLength": 1,
      "title": "Subject Id",
      "type": "string"
    },
    "subject_revision": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Subject Revision"
    },
    "subject_type": {
      "minLength": 1,
      "title": "Subject Type",
      "type": "string"
    }
  },
  "required": [
    "subject_type",
    "subject_id",
    "subject_hash"
  ],
  "title": "WeaknessVerificationSubject",
  "type": "object"
}
