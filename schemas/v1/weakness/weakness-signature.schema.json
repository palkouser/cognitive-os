{
  "$defs": {
    "WeaknessComponentType": {
      "enum": [
        "controller",
        "context",
        "retrieval",
        "provider",
        "model",
        "tool",
        "verifier",
        "memory",
        "semantic_memory",
        "skill",
        "strategy",
        "experience",
        "corpus",
        "routing",
        "sandbox",
        "unknown"
      ],
      "title": "WeaknessComponentType",
      "type": "string"
    },
    "WeaknessType": {
      "enum": [
        "model_routing_failure",
        "tool_routing_failure",
        "provider_structured_output_failure",
        "provider_availability_failure",
        "context_required_item_missing",
        "context_irrelevant_content",
        "context_budget_failure",
        "retrieval_recall_failure",
        "retrieval_scope_or_sensitivity_denial",
        "missing_skill",
        "skill_precondition_failure",
        "skill_execution_failure",
        "strategy_mismatch",
        "strategy_fallback_overuse",
        "verifier_gap",
        "verifier_instability",
        "memory_retrieval_failure",
        "semantic_contradiction_block",
        "corpus_coverage_gap",
        "excessive_repair",
        "excessive_iteration",
        "unnecessary_provider_call",
        "unnecessary_tool_call",
        "cost_regression",
        "latency_regression",
        "policy_denial_pattern",
        "sandbox_failure",
        "user_correction_pattern",
        "unknown"
      ],
      "title": "WeaknessType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/weakness/weakness-signature.schema.json",
  "additionalProperties": false,
  "properties": {
    "component_identity": {
      "minLength": 1,
      "title": "Component Identity",
      "type": "string"
    },
    "component_type": {
      "$ref": "#/$defs/WeaknessComponentType"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "context_source_type": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Context Source Type"
    },
    "corpus_destination": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Corpus Destination"
    },
    "model_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Identity"
    },
    "normalized_failure_code": {
      "minLength": 1,
      "title": "Normalized Failure Code",
      "type": "string"
    },
    "normalized_problem_signature": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Normalized Problem Signature",
      "type": "string"
    },
    "provider_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Identity"
    },
    "retrieval_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retrieval Identity"
    },
    "risk_class": {
      "minLength": 1,
      "title": "Risk Class",
      "type": "string"
    },
    "routing_policy_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Routing Policy Identity"
    },
    "scope": {
      "minLength": 1,
      "title": "Scope",
      "type": "string"
    },
    "signature_version": {
      "default": "weakness-signature-v1",
      "minLength": 1,
      "title": "Signature Version",
      "type": "string"
    },
    "skill_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Skill Identity"
    },
    "strategy_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Strategy Identity"
    },
    "tool_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool Identity"
    },
    "verifier_identity": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Verifier Identity"
    },
    "weakness_type": {
      "$ref": "#/$defs/WeaknessType"
    }
  },
  "required": [
    "weakness_type",
    "normalized_problem_signature",
    "normalized_failure_code",
    "component_type",
    "component_identity",
    "risk_class",
    "scope"
  ],
  "title": "WeaknessSignature",
  "type": "object"
}
