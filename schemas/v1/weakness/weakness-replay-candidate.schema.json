{
  "$id": "https://cognitive-os.local/schemas/v1/weakness/weakness-replay-candidate.schema.json",
  "additionalProperties": false,
  "properties": {
    "candidate_id": {
      "format": "uuid",
      "title": "Candidate Id",
      "type": "string"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "expected_result_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Expected Result Hash",
      "type": "string"
    },
    "proposal_only": {
      "default": true,
      "title": "Proposal Only",
      "type": "boolean"
    },
    "request_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Request Hash",
      "type": "string"
    },
    "source_snapshot_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Source Snapshot Hash",
      "type": "string"
    },
    "weakness_revision_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Weakness Revision Hash",
      "type": "string"
    }
  },
  "required": [
    "candidate_id",
    "weakness_revision_hash",
    "source_snapshot_hash",
    "request_hash",
    "expected_result_hash"
  ],
  "title": "WeaknessReplayCandidate",
  "type": "object"
}
