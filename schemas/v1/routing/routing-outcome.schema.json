{
  "$defs": {
    "RoutingOutcomeStatus": {
      "enum": [
        "accepted",
        "rejected",
        "failed",
        "cancelled",
        "unverifiable"
      ],
      "title": "RoutingOutcomeStatus",
      "type": "string"
    },
    "TokenUsage": {
      "additionalProperties": false,
      "properties": {
        "cached_input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cached Input Tokens"
        },
        "input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "output_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "reasoning_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Tokens"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        }
      },
      "title": "TokenUsage",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/routing/routing-outcome.schema.json",
  "additionalProperties": false,
  "properties": {
    "acceptance_decision_reference": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Acceptance Decision Reference"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "context_bundle_reference": {
      "minLength": 1,
      "title": "Context Bundle Reference",
      "type": "string"
    },
    "cost_units": {
      "anyOf": [
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Units"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "decision_id": {
      "format": "uuid",
      "title": "Decision Id",
      "type": "string"
    },
    "fallback_used": {
      "default": false,
      "title": "Fallback Used",
      "type": "boolean"
    },
    "latency_ms": {
      "anyOf": [
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latency Ms"
    },
    "outcome_id": {
      "format": "uuid",
      "title": "Outcome Id",
      "type": "string"
    },
    "provider_request_reference": {
      "minLength": 1,
      "title": "Provider Request Reference",
      "type": "string"
    },
    "provider_result_reference": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Result Reference"
    },
    "repair_count": {
      "default": 0,
      "minimum": 0,
      "title": "Repair Count",
      "type": "integer"
    },
    "safety_result": {
      "default": "unknown",
      "minLength": 1,
      "title": "Safety Result",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/RoutingOutcomeStatus"
    },
    "task_run_id": {
      "format": "uuid",
      "title": "Task Run Id",
      "type": "string"
    },
    "token_usage": {
      "anyOf": [
        {
          "$ref": "#/$defs/TokenUsage"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "tool_result_references": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Tool Result References",
      "type": "array"
    },
    "verifier_bundle_reference": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Verifier Bundle Reference"
    }
  },
  "required": [
    "outcome_id",
    "decision_id",
    "task_run_id",
    "provider_request_reference",
    "context_bundle_reference",
    "status",
    "created_at"
  ],
  "title": "RoutingOutcome",
  "type": "object"
}
