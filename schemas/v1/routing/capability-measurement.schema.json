{
  "$defs": {
    "CapabilityCohort": {
      "additionalProperties": false,
      "properties": {
        "cohort_level": {
          "minLength": 1,
          "title": "Cohort Level",
          "type": "string"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "parent_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Hash"
        },
        "task_signature_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Task Signature Hash",
          "type": "string"
        }
      },
      "required": [
        "task_signature_hash",
        "cohort_level"
      ],
      "title": "CapabilityCohort",
      "type": "object"
    },
    "CapabilityDimension": {
      "enum": [
        "accepted_task_rate",
        "verifier_quality",
        "structured_output_validity",
        "tool_call_validity",
        "repair_count",
        "provider_failure_rate",
        "timeout_rate",
        "latency",
        "input_token_usage",
        "output_token_usage",
        "cost_units",
        "context_fit",
        "policy_denial_rate",
        "safety_failure_rate",
        "coding_benchmark_quality",
        "task_signature_coverage"
      ],
      "title": "CapabilityDimension",
      "type": "string"
    },
    "CapabilityEvidenceType": {
      "enum": [
        "provider_self_description",
        "provider_documentation",
        "operator_declaration",
        "replay_contract_evidence",
        "deterministic_benchmark",
        "opt_in_live_benchmark",
        "verified_task_outcome"
      ],
      "title": "CapabilityEvidenceType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/routing/capability-measurement.schema.json",
  "additionalProperties": false,
  "properties": {
    "cohort": {
      "$ref": "#/$defs/CapabilityCohort"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "dimension": {
      "$ref": "#/$defs/CapabilityDimension"
    },
    "evidence_type": {
      "$ref": "#/$defs/CapabilityEvidenceType"
    },
    "measurement_id": {
      "format": "uuid",
      "title": "Measurement Id",
      "type": "string"
    },
    "model_identity_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Model Identity Hash",
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "title": "Observed At",
      "type": "string"
    },
    "source_refs": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "minItems": 1,
      "title": "Source Refs",
      "type": "array"
    },
    "succeeded": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Succeeded"
    },
    "value": {
      "anyOf": [
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Value"
    }
  },
  "required": [
    "measurement_id",
    "model_identity_hash",
    "cohort",
    "dimension",
    "value",
    "evidence_type",
    "source_refs",
    "observed_at"
  ],
  "title": "CapabilityMeasurement",
  "type": "object"
}
