{
  "$defs": {
    "RoutingAccessType": {
      "enum": [
        "profile_lookup",
        "observation_ingestion",
        "statistics_read",
        "policy_lookup",
        "routing_decision",
        "shadow_decision",
        "experiment_read",
        "promotion_assessment",
        "outcome_read"
      ],
      "title": "RoutingAccessType",
      "type": "string"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/routing/routing-access-record.schema.json",
  "additionalProperties": false,
  "properties": {
    "access_id": {
      "format": "uuid",
      "title": "Access Id",
      "type": "string"
    },
    "access_type": {
      "$ref": "#/$defs/RoutingAccessType"
    },
    "accessed_at": {
      "format": "date-time",
      "title": "Accessed At",
      "type": "string"
    },
    "actor_id": {
      "minLength": 1,
      "title": "Actor Id",
      "type": "string"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "decision_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Decision Id"
    },
    "model_identity_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Identity Hash"
    },
    "policy_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Policy Id"
    },
    "policy_revision": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Policy Revision"
    },
    "reason": {
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    }
  },
  "required": [
    "access_id",
    "access_type",
    "actor_id",
    "accessed_at",
    "reason"
  ],
  "title": "RoutingAccessRecord",
  "type": "object"
}
