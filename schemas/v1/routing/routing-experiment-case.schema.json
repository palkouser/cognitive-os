{
  "$defs": {
    "CapabilitySupportStatus": {
      "enum": [
        "supported",
        "unsupported",
        "unknown",
        "restricted"
      ],
      "title": "CapabilitySupportStatus",
      "type": "string"
    },
    "ContextRequirement": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "estimated_tokens": {
          "minimum": 0,
          "title": "Estimated Tokens",
          "type": "integer"
        },
        "required_modalities": {
          "default": [
            "text"
          ],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Modalities",
          "type": "array"
        },
        "reserved_output_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Reserved Output Tokens",
          "type": "integer"
        }
      },
      "required": [
        "estimated_tokens"
      ],
      "title": "ContextRequirement",
      "type": "object"
    },
    "ContextSizeClass": {
      "enum": [
        "small",
        "medium",
        "large",
        "long",
        "unknown"
      ],
      "title": "ContextSizeClass",
      "type": "string"
    },
    "CostClass": {
      "enum": [
        "low",
        "standard",
        "premium",
        "unknown"
      ],
      "title": "CostClass",
      "type": "string"
    },
    "ExecutionRole": {
      "enum": [
        "primary",
        "fallback",
        "planner",
        "executor",
        "generator",
        "critic",
        "proposer"
      ],
      "title": "ExecutionRole",
      "type": "string"
    },
    "LatencyClass": {
      "enum": [
        "low",
        "standard",
        "relaxed",
        "unknown"
      ],
      "title": "LatencyClass",
      "type": "string"
    },
    "ModelCapabilityRequirement": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "dimension": {
          "minLength": 1,
          "title": "Dimension",
          "type": "string"
        },
        "hard": {
          "default": true,
          "title": "Hard",
          "type": "boolean"
        },
        "minimum_value": {
          "anyOf": [
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum Value"
        },
        "required_support": {
          "anyOf": [
            {
              "$ref": "#/$defs/CapabilitySupportStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "dimension"
      ],
      "title": "ModelCapabilityRequirement",
      "type": "object"
    },
    "OperatorRoutingRestriction": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "allowed_model_hashes": {
          "default": [],
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Allowed Model Hashes",
          "type": "array"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "denied_model_hashes": {
          "default": [],
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Denied Model Hashes",
          "type": "array"
        },
        "preferred_model_hashes": {
          "default": [],
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Preferred Model Hashes",
          "type": "array"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "actor_id",
        "reason"
      ],
      "title": "OperatorRoutingRestriction",
      "type": "object"
    },
    "ProviderHealthSnapshot": {
      "additionalProperties": false,
      "properties": {
        "checked_at": {
          "format": "date-time",
          "title": "Checked At",
          "type": "string"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "provider_id": {
          "minLength": 1,
          "title": "Provider Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ProviderStatus"
        }
      },
      "required": [
        "provider_id",
        "status",
        "checked_at"
      ],
      "title": "ProviderHealthSnapshot",
      "type": "object"
    },
    "ProviderPolicyConstraint": {
      "additionalProperties": false,
      "properties": {
        "allowed_provider_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Allowed Provider Ids",
          "type": "array"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "denied_provider_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Denied Provider Ids",
          "type": "array"
        },
        "require_healthy": {
          "default": true,
          "title": "Require Healthy",
          "type": "boolean"
        }
      },
      "title": "ProviderPolicyConstraint",
      "type": "object"
    },
    "ProviderRegistrySnapshot": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "health": {
          "items": {
            "$ref": "#/$defs/ProviderHealthSnapshot"
          },
          "maxItems": 256,
          "title": "Health",
          "type": "array"
        }
      },
      "required": [
        "health"
      ],
      "title": "ProviderRegistrySnapshot",
      "type": "object"
    },
    "ProviderStatus": {
      "enum": [
        "available",
        "degraded",
        "unavailable",
        "misconfigured",
        "unauthenticated"
      ],
      "title": "ProviderStatus",
      "type": "string"
    },
    "RoutingBudget": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "maximum_calls": {
          "default": 1,
          "maximum": 8,
          "minimum": 1,
          "title": "Maximum Calls",
          "type": "integer"
        },
        "maximum_cost_units": {
          "anyOf": [
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Cost Units"
        },
        "maximum_seconds": {
          "default": "120",
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "title": "Maximum Seconds",
          "type": "string"
        },
        "maximum_tokens": {
          "default": 131072,
          "minimum": 1,
          "title": "Maximum Tokens",
          "type": "integer"
        },
        "maximum_tool_calls": {
          "default": 32,
          "minimum": 0,
          "title": "Maximum Tool Calls",
          "type": "integer"
        }
      },
      "title": "RoutingBudget",
      "type": "object"
    },
    "RoutingRequest": {
      "additionalProperties": false,
      "properties": {
        "budget": {
          "$ref": "#/$defs/RoutingBudget"
        },
        "capability_requirements": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ModelCapabilityRequirement"
          },
          "title": "Capability Requirements",
          "type": "array"
        },
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "context_requirement": {
          "$ref": "#/$defs/ContextRequirement"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "execution_role": {
          "$ref": "#/$defs/ExecutionRole"
        },
        "operator_restriction": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperatorRoutingRestriction"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "policy_id": {
          "minLength": 1,
          "title": "Policy Id",
          "type": "string"
        },
        "policy_revision": {
          "exclusiveMinimum": 0,
          "title": "Policy Revision",
          "type": "integer"
        },
        "provider_constraints": {
          "$ref": "#/$defs/ProviderPolicyConstraint"
        },
        "provider_registry_snapshot": {
          "$ref": "#/$defs/ProviderRegistrySnapshot"
        },
        "requested_by": {
          "minLength": 1,
          "title": "Requested By",
          "type": "string"
        },
        "routing_request_id": {
          "format": "uuid",
          "title": "Routing Request Id",
          "type": "string"
        },
        "skill_references": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Skill References",
          "type": "array"
        },
        "step_id": {
          "minLength": 1,
          "title": "Step Id",
          "type": "string"
        },
        "strategy_references": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Strategy References",
          "type": "array"
        },
        "task_run_id": {
          "format": "uuid",
          "title": "Task Run Id",
          "type": "string"
        },
        "task_signature": {
          "$ref": "#/$defs/TaskSignature"
        }
      },
      "required": [
        "routing_request_id",
        "task_run_id",
        "step_id",
        "task_signature",
        "execution_role",
        "provider_constraints",
        "context_requirement",
        "budget",
        "policy_id",
        "policy_revision",
        "provider_registry_snapshot",
        "requested_by",
        "created_at"
      ],
      "title": "RoutingRequest",
      "type": "object"
    },
    "TaskComplexityClass": {
      "enum": [
        "trivial",
        "small",
        "medium",
        "large",
        "long_horizon",
        "unknown"
      ],
      "title": "TaskComplexityClass",
      "type": "string"
    },
    "TaskSignature": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "default": "",
          "title": "Content Hash",
          "type": "string"
        },
        "context_size_class": {
          "$ref": "#/$defs/ContextSizeClass",
          "default": "unknown"
        },
        "cost_class": {
          "$ref": "#/$defs/CostClass",
          "default": "unknown"
        },
        "estimated_complexity": {
          "$ref": "#/$defs/TaskComplexityClass",
          "default": "unknown"
        },
        "execution_role": {
          "$ref": "#/$defs/ExecutionRole",
          "default": "primary"
        },
        "latency_class": {
          "$ref": "#/$defs/LatencyClass",
          "default": "unknown"
        },
        "output_type": {
          "minLength": 1,
          "title": "Output Type",
          "type": "string"
        },
        "problem_class": {
          "minLength": 1,
          "title": "Problem Class",
          "type": "string"
        },
        "problem_domain": {
          "minLength": 1,
          "title": "Problem Domain",
          "type": "string"
        },
        "profile_version": {
          "default": "task-signature-v1",
          "minLength": 1,
          "title": "Profile Version",
          "type": "string"
        },
        "repository_profile": {
          "default": "unknown",
          "minLength": 1,
          "title": "Repository Profile",
          "type": "string"
        },
        "required_structured_output": {
          "default": false,
          "title": "Required Structured Output",
          "type": "boolean"
        },
        "required_tool_capabilities": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Required Tool Capabilities",
          "type": "array"
        },
        "risk_level": {
          "default": "standard",
          "minLength": 1,
          "title": "Risk Level",
          "type": "string"
        },
        "skill_revisions": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Skill Revisions",
          "type": "array"
        },
        "strategy_revisions": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Strategy Revisions",
          "type": "array"
        },
        "verifier_profile": {
          "default": "default",
          "minLength": 1,
          "title": "Verifier Profile",
          "type": "string"
        }
      },
      "required": [
        "problem_domain",
        "problem_class",
        "output_type"
      ],
      "title": "TaskSignature",
      "type": "object"
    }
  },
  "$id": "https://cognitive-os.local/schemas/v1/routing/routing-experiment-case.schema.json",
  "additionalProperties": false,
  "properties": {
    "case_id": {
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "content_hash": {
      "default": "",
      "title": "Content Hash",
      "type": "string"
    },
    "expected_static_model_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expected Static Model Hash"
    },
    "routing_request": {
      "$ref": "#/$defs/RoutingRequest"
    }
  },
  "required": [
    "case_id",
    "routing_request"
  ],
  "title": "RoutingExperimentCase",
  "type": "object"
}
